local function getHWID()
    return game:GetService("RbxAnalyticsService"):GetClientId()
end

local function checkKey(key)
    local hwid = getHWID()
    local url  = DEPLOY_URL .. "?key=" .. key .. "&hwid=" .. hwid
    local ok, res = pcall(function() return game:HttpGet(url) end)
    if not ok then return false, "Khong ket noi duoc server" end
    if res == "SUCCESS"       then return true,  "OK" end
    if res == "HWID_MISMATCH" then return false, "Key nay da dung tren may khac!" end
    if res == "INVALID_KEY"   then return false, "Key khong hop le!" end
    return false, "Loi: " .. tostring(res)
end

