    saveGBtn.Size = UDim2.new(0.48,0,0,28); saveGBtn.Position = UDim2.new(0.52,0,0,128)
    saveGBtn.BackgroundColor3 = C.green; saveGBtn.BorderSizePixel = 0
    saveGBtn.Text = "Save to _G"; saveGBtn.TextColor3 = Color3.fromRGB(10,10,10)
    saveGBtn.TextSize = 11; saveGBtn.Font = Enum.Font.GothamBold; corner(6, saveGBtn)

    local function buildConfigString()
        local mobList = {}
        for name, _ in pairs(selectedMobs) do table.insert(mobList, '"'..name..'"') end
        table.sort(mobList)
        local lines = {
            "_G.TuanhConfig = {",
            "    autoAttack     = " .. tostring(autoAttack) .. ",",
            "    autoSpawnTP    = " .. tostring(autoSpawnTP) .. ",",
            "    autoSpawnClick = " .. tostring(autoSpawnClick) .. ",",
            "    smeltMethod    = " .. tostring(smeltMethod) .. ",",
            "    equippedWeapon = " .. (equippedWeapon and ('"'..equippedWeapon..'"') or "nil") .. ",",
            "    selectedMobs   = {" .. table.concat(mobList, ", ") .. "},",
            "}",
        }
        return table.concat(lines, "\n")
    end

    exportBtn.MouseButton1Click:Connect(function()
        local cfg = buildConfigString()
        outputBox.Text = cfg; outputBox.TextColor3 = C.cyan
        setclipboard(cfg)
        exportStatus.Text = "Copied to clipboard!"; exportStatus.TextColor3 = C.green
        task.delay(4, function() exportStatus.Text = "" end)
    end)

    saveGBtn.MouseButton1Click:Connect(function()
        local mobList = {}
        for name, _ in pairs(selectedMobs) do table.insert(mobList, name) end
        _G.TuanhConfig = {
            autoAttack=autoAttack, autoSpawnTP=autoSpawnTP, autoSpawnClick=autoSpawnClick,
            smeltMethod=smeltMethod, equippedWeapon=equippedWeapon, selectedMobs=mobList,
        }
        exportStatus.Text = "Saved to _G!"; exportStatus.TextColor3 = C.yellow
        cfgBadge.BackgroundColor3 = Color3.fromRGB(20,50,20)
        cfgTxt.Text = "Config saved to _G.TuanhConfig"; cfgTxt.TextColor3 = C.green
        task.delay(3, function() exportStatus.Text = "" end)
    end)
end

