local RS = game:GetService("ReplicatedStorage")

local function getPlaceRF()
    return RS.Packages._Index["sleitnick_knit@1.7.0"].knit.Services.TowerService.RF.PlaceUnit
end

local function getUpgradeRF()
    return RS.Packages._Index["sleitnick_knit@1.7.0"].knit.Services.TowerService.RF.UpgradeUnit
end

local recording = {}
local isRecording = false
local isReplaying = false

-- Hook để record
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if isRecording and method == "InvokeServer" then
        if self.Name == "PlaceUnit" then
            table.insert(recording, {
                type = "place",
                time = tick(),
                args = {args[1], args[2]}
            })
            print("📍 Record Place:", args[1], args[2])

        elseif self.Name == "UpgradeUnit" then
            table.insert(recording, {
                type = "upgrade",
                time = tick(),
                args = {args[1]}
            })
            print("⬆️ Record Upgrade:", args[1])
        end
    end

    return oldNamecall(self, ...)
end

setreadonly(mt, true)

-- Replay
local function replay()
    if #recording == 0 then
        print("❌ Chưa có gì được record!")
        return
    end

    isReplaying = true
    print("▶️ Bắt đầu replay", #recording, "actions...")

    for i, action in ipairs(recording) do
        if not isReplaying then break end

        if i > 1 then
            local delay = recording[i].time - recording[i-1].time
            task.wait(delay)
        end

        if not isReplaying then break end

        pcall(function()
            if action.type == "place" then
                getPlaceRF():InvokeServer(unpack(action.args))
                print("📍 Replay Place:", action.args[1])

            elseif action.type == "upgrade" then
                getUpgradeRF():InvokeServer(unpack(action.args))
                print("⬆️ Replay Upgrade:", action.args[1])
            end
        end)
    end

    print("✅ Replay xong!")
    isReplaying = false
end

