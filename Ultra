local function makeBtn(text, y, color)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Position = UDim2.new(0, 5, 0, y)
    btn.BackgroundColor3 = color
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    return btn
end

local btnRecord = makeBtn("⏺ Bắt đầu Record", 55, Color3.fromRGB(180, 0, 0))
local btnStop   = makeBtn("⏹ Dừng Record", 92, Color3.fromRGB(80, 80, 80))
local btnReplay = makeBtn("▶️ Replay 1 lần", 129, Color3.fromRGB(0, 120, 0))
local btnLoop   = makeBtn("🔁 Loop Replay: TẮT", 166, Color3.fromRGB(60, 20, 80))

-- resize frame
frame.Size = UDim2.new(0, 210, 0, 205)

local loopReplay = false
local loopThread = nil

btnRecord.MouseButton1Click:Connect(function()
    if isReplaying then
        print("❌ Đang replay, dừng lại trước!")
        return
    end
    recording = {}
    isRecording = true
    countLabel.Text = "📋 Actions: 0"
    btnRecord.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    btnRecord.Text = "🔴 Đang Record..."
    print("⏺ Đang record! Hãy đặt và nâng cấp unit!")
end)

btnStop.MouseButton1Click:Connect(function()
    isRecording = false
    btnRecord.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    btnRecord.Text = "⏺ Bắt đầu Record"
    countLabel.Text = "📋 Actions: " .. #recording
    print("⏹ Dừng record! Đã lưu", #recording, "actions")
end)

-- Cập nhật count khi record
task.spawn(function()
    while true do
        task.wait(0.5)
        if isRecording then
            countLabel.Text = "📋 Actions: " .. #recording
        end
    end
end)

btnReplay.MouseButton1Click:Connect(function()
    if isReplaying then
        isReplaying = false
        btnReplay.Text = "▶️ Replay 1 lần"
        btnReplay.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
        print("⏹ Dừng replay!")
        return
    end
    btnReplay.Text = "⏹ Dừng Replay"
    btnReplay.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    task.spawn(function()
        replay()
        btnReplay.Text = "▶️ Replay 1 lần"
        btnReplay.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
    end)
end)

btnLoop.MouseButton1Click:Connect(function()
    loopReplay = not loopReplay
    if loopReplay then
        btnLoop.Text = "🔁 Loop Replay: BẬT"
        btnLoop.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
        loopThread = task.spawn(function()
            while loopReplay do
                replay()
                if loopReplay then
                    print("🔁 Lặp lại sau 2s...")
                    task.wait(2)
                end
            end
        end)
    else
        btnLoop.Text = "🔁 Loop Replay: TẮT"
        btnLoop.BackgroundColor3 = Color3.fromRGB(60, 20, 80)
        isReplaying = false
        if loopThread then
            pcall(function() task.cancel(loopThread) end)
            loopThread = nil
        end
        print("⏹ Dừng loop!")
    end
end)

print("✅ Record/Replay loaded!")
print("1. Bấm Record → đặt unit → nâng cấp")
print("2. Bấm Stop → Replay hoặc Loop")
