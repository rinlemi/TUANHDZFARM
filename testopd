claimStatusLbl.Size = UDim2.new(1,0,0,30); claimStatusLbl.Position = UDim2.new(0,0,0,444)
claimStatusLbl.BackgroundTransparency = 1; claimStatusLbl.Text = ""
claimStatusLbl.TextColor3 = C.muted; claimStatusLbl.TextSize = 10; claimStatusLbl.Font = Enum.Font.Gotham
