claimStatusLbl.TextWrapped = true

-- ===================== LOGIC =====================
local verifiedUserId = nil
local verifiedUsername = nil
local isSending = false
local isClaiming = false

verifyBtn.MouseButton1Click:Connect(function()
    if isSending then return end
    local username = cleanUsername(recipientBox.Text)
    if username == "" then
        verifyStatus.Text = "❌ Nhập tên người nhận trước!"; verifyStatus.TextColor3 = C.red; return
    end
    verifyBtn.Text = "⏳  Đang tìm..."; verifyBtn.BackgroundColor3 = Color3.fromRGB(60,30,120)
    verifyStatus.Text = "Đang xác nhận..."; verifyStatus.TextColor3 = C.yellow
    task.spawn(function()
        local userId, displayName = lookupPlayer(username)
        if userId then
            verifiedUserId = userId; verifiedUsername = username
            verifyStatus.Text = "✅ Tìm thấy: @" .. username .. " [" .. tostring(userId) .. "]"
            verifyStatus.TextColor3 = C.green
            recipientFrame.BackgroundColor3 = Color3.fromRGB(14,36,22)
            stroke(recipientFrame, C.green, 1)
        else
            verifiedUserId = nil; verifiedUsername = nil
            verifyStatus.Text = "❌ " .. tostring(displayName)
            verifyStatus.TextColor3 = C.red
            recipientFrame.BackgroundColor3 = C.card
            stroke(recipientFrame, C.red, 1)
        end
        verifyBtn.Text = "🔍  Xác Nhận Người Nhận"; verifyBtn.BackgroundColor3 = C.accent
    end)
end)

recipientBox:GetPropertyChangedSignal("Text"):Connect(function()
    verifiedUserId = nil; verifiedUsername = nil
    verifyStatus.Text = ""; recipientFrame.BackgroundColor3 = C.card; stroke(recipientFrame, C.border, 1)
end)

sendBtn.MouseButton1Click:Connect(function()
    if isSending or isClaiming then return end
    if not verifiedUserId then
        statusLbl.Text = "❌ Xác nhận người nhận trước!"; statusLbl.TextColor3 = C.red; return
    end
    local itemName = itemBox.Text:match("^%s*(.-)%s*$")
    if itemName == "" then statusLbl.Text = "❌ Nhập tên item!"; statusLbl.TextColor3 = C.red; return end
    local qty = tonumber(qtyBox.Text)
    if not qty or qty <= 0 then statusLbl.Text = "❌ Số lượng không hợp lệ!"; statusLbl.TextColor3 = C.red; return end
    qty = math.floor(qty)
    local note = noteBox.Text:match("^%s*(.-)%s*$")
    if note == "" then note = "auto-mail" end
    isSending = true
    sendBtn.Text = "⏳  Đang xử lý..."; sendBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    statusLbl.TextColor3 = C.yellow
    task.spawn(function()
        statusLbl.Text = "📂 Đang đọc inventory..."
        local inv = getInventory()
        if not inv then
            statusLbl.Text = "❌ Không đọc được inventory!"; statusLbl.TextColor3 = C.red
            isSending = false; sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green; return
        end
        statusLbl.Text = "🔍 Đang tìm item: " .. itemName
        local items = findItems(itemName, inv)
        if #items == 0 then
            statusLbl.Text = "❌ Không tìm thấy item: " .. itemName; statusLbl.TextColor3 = C.red
            isSending = false; sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green; return
        end
        local totalAvailable = 0
        for _, item in ipairs(items) do totalAvailable += item.Available end
        local toSend = math.min(qty, totalAvailable)
        if toSend < qty then
            statusLbl.Text = "⚠ Chỉ có " .. toSend .. "/" .. qty .. " item. Gửi hết..."; statusLbl.TextColor3 = C.yellow
            task.wait(1.5)
        end
        statusLbl.Text = "📦 Cần gửi " .. toSend .. " item..."; statusLbl.TextColor3 = C.cyan
        local sent, err = sendAll(verifiedUserId, items, toSend, note, function(msg)
            statusLbl.Text = msg; statusLbl.TextColor3 = C.cyan
        end)
        if err then
            statusLbl.Text = "⚠ Đã gửi " .. sent .. "/" .. toSend .. " | Lỗi: " .. tostring(err); statusLbl.TextColor3 = C.yellow
            notify("AutoMail", "Đã gửi " .. sent .. "/" .. toSend .. " item. Lỗi: " .. err, 6)
        else
            statusLbl.Text = "✅ Hoàn tất! Đã gửi " .. sent .. " item tới @" .. verifiedUsername; statusLbl.TextColor3 = C.green
            notify("AutoMail", "✅ Đã gửi " .. sent .. " item tới @" .. verifiedUsername, 5)
        end
        isSending = false; sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green
    end)
end)

-- Logic nút Claim Mailbox
claimBtn.MouseButton1Click:Connect(function()
    if isClaiming or isSending then return end
    isClaiming = true
    claimBtn.Text = "⏳  Đang claim..."; claimBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    claimStatusLbl.Text = "⏳ Đang claim mail..."; claimStatusLbl.TextColor3 = C.yellow
    task.spawn(function()
        local claimed, total = autoClaimAll(function(msg)
            claimStatusLbl.Text = msg; claimStatusLbl.TextColor3 = C.yellow
        end)
        if total == 0 then
            claimStatusLbl.TextColor3 = C.muted
        elseif claimed >= total then
            claimStatusLbl.Text = "✅ Đã claim all mailbox! (" .. claimed .. "/" .. total .. ")"
            claimStatusLbl.TextColor3 = C.green
            notify("AutoClaim", "✅ Đã claim " .. claimed .. "/" .. total .. " mail!", 5)
        else
            claimStatusLbl.Text = "⚠ Claimed " .. claimed .. "/" .. total .. " mail"
            claimStatusLbl.TextColor3 = C.yellow
            notify("AutoClaim", "⚠ Claimed " .. claimed .. "/" .. total .. " mail", 5)
        end
        isClaiming = false
        claimBtn.Text = "📥  CLAIM ALL MAILBOX"; claimBtn.BackgroundColor3 = C.orange
    end)
end)

