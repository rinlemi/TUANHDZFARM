sendBtn.MouseButton1Click:Connect(function()
    if isSending or isClaiming then return end
    if not verifiedUserId then
        statusLbl.Text = "❌ Please verify the recipient first!"; statusLbl.TextColor3 = C.red; return
    end

    local selections = {}
    for groupKey, st in pairs(selectedState) do
        if st.checked then
            local qty = tonumber(st.qtyBox.Text) or 0
            qty = math.floor(qty)
            if qty > 0 then
                table.insert(selections, {Group = st.group, RequestedQty = math.min(qty, st.group.Available)})
            end
        end
    end

    if #selections == 0 then
        statusLbl.Text = "❌ No items selected (check a box and enter a quantity)!"; statusLbl.TextColor3 = C.red; return
    end

    local note = noteBox.Text:match("^%s*(.-)%s*$")
    if note == "" then note = "auto-mail" end

    isSending = true
    sendBtn.Text = "⏳  Sending..."; sendBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    statusLbl.TextColor3 = C.yellow
    statusLbl.Text = "📦 Preparing to send " .. tostring(#selections) .. " item type(s)..."

    task.spawn(function()
        local sent, err, sentDetails = sendSelectedGroups(verifiedUserId, selections, note, function(msg)
            statusLbl.Text = msg; statusLbl.TextColor3 = C.cyan
        end)

        -- Build a detailed item list for the notification, e.g. "Bamboo x50, Super Sprinkler x1"
        local detailParts = {}
        for _, d in ipairs(sentDetails) do
            table.insert(detailParts, tostring(d.Name) .. " x" .. tostring(d.Qty))
        end
        local detailText = table.concat(detailParts, ", ")
        local recipientLabel = "@" .. tostring(verifiedUsername)

        if err then
            statusLbl.Text = "⚠ Sent " .. sent .. " item(s) | Error: " .. tostring(err)
            statusLbl.TextColor3 = C.yellow
            notify(
                "AutoMail",
                "Partially sent to " .. recipientLabel .. ": " .. detailText .. " | Error: " .. tostring(err),
                7
            )
        else
            statusLbl.Text = "✅ Done! Sent " .. sent .. " item(s) to " .. recipientLabel
            statusLbl.TextColor3 = C.green
            notify(
                "AutoMail",
                "Sent to " .. recipientLabel .. ": " .. detailText,
                6
            )
        end

        isSending = false
        sendBtn.Text = "📬  SEND SELECTED ITEMS"; sendBtn.BackgroundColor3 = C.green
        refreshList()
    end)
end)

