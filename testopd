local function waitLocalReplica(timeout)
    local replica = nil
    if PlayerStateClient and type(PlayerStateClient.WaitForLocalReplica) == "function" then
        local ok, result = pcall(function() return PlayerStateClient:WaitForLocalReplica(timeout or 30) end)
        if ok then replica = result end
    end
    if not replica and PlayerStateClient and type(PlayerStateClient.GetLocalReplica) == "function" then
        local started = os.clock()
        repeat
            local ok, result = pcall(function() return PlayerStateClient:GetLocalReplica() end)
            if ok and result then replica = result; break end
            task.wait(0.25)
        until os.clock() - started > (timeout or 30)
    end
    return replica
end

local function getInventory()
    local replica = waitLocalReplica(30)
    if not replica or type(replica.Data) ~= "table" or type(replica.Data.Inventory) ~= "table" then return nil end
    return replica.Data.Inventory
end

