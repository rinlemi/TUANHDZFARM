-- Danh sách mob đã thấy (tránh trùng)
local mobButtons = {}

local function refreshList()
	for _, v in ipairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
	mobButtons = {}

	-- Gom tên mob unique
	local seen = {}
	for _, mob in ipairs(workspace.Enemies:GetChildren()) do
		local hum = mob:FindFirstChild("Humanoid")
		if hum and hum.Health > 0 and not seen[mob.Name] then
			seen[mob.Name] = true

			local btn = Instance.new("TextButton", scroll)
			btn.Size = UDim2.new(1, -5, 0, 30)
			btn.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
			btn.BorderSizePixel = 0
			btn.Text = "👾 " .. mob.Name
			btn.TextColor3 = Color3.fromRGB(220, 220, 220)
			btn.TextSize = 11
			btn.Font = Enum.Font.GothamBold
			btn.TextXAlignment = Enum.TextXAlignment.Left
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
			local pad = Instance.new("UIPadding", btn)
			pad.PaddingLeft = UDim.new(0, 8)

			btn.MouseButton1Click:Connect(function()
				selectedMob = mob.Name
				statusLabel.Text = "✅ Chọn: " .. mob.Name
				statusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
				for _, b in ipairs(scroll:GetChildren()) do
					if b:IsA("TextButton") then
						b.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
					end
				end
				btn.BackgroundColor3 = Color3.fromRGB(0, 80, 160)
			end)

			table.insert(mobButtons, btn)
		end
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 5)
	print("✅ Làm mới xong! " .. #mobButtons .. " loại mob")
end

-- Pull logic
local function startPull()
	if not selectedMob then
		statusLabel.Text = "❌ Chọn mob trước!"
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		return
	end
	pulling = true
	pullBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
	pullBtn.Text = "🔥 Đang kéo: " .. selectedMob
	statusLabel.Text = "🔥 Kéo: " .. selectedMob

	pullThread = task.spawn(function()
		while pulling do
			local char = player.Character
			if not char then task.wait(0.1) continue end
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then task.wait(0.1) continue end

			for _, mob in ipairs(workspace.Enemies:GetChildren()) do
				if mob.Name ~= selectedMob then continue end
				local mobHrp = mob:FindFirstChild("HumanoidRootPart")
				local hum = mob:FindFirstChild("Humanoid")
				if not mobHrp or not hum or hum.Health <= 0 then continue end
				mobHrp.CFrame = hrp.CFrame
			end
			task.wait(0.05)
		end
	end)
end

local function stopPull()
	pulling = false
	if pullThread then
		task.cancel(pullThread)
		pullThread = nil
	end
	pullBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 0)
	pullBtn.Text = "🔴 Kéo Mob"
	statusLabel.Text = "⏹ Đã dừng"
	statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
end

refreshBtn.MouseButton1Click:Connect(refreshList)
pullBtn.MouseButton1Click:Connect(function()
	if pulling then stopPull() else startPull() end
end)
stopBtn.MouseButton1Click:Connect(stopPull)

-- Auto refresh khi mob mới spawn
workspace.Enemies.ChildAdded:Connect(function()
	task.wait(0.5)
	refreshList()
end)
workspace.Enemies.ChildRemoved:Connect(function()
	task.wait(0.5)
	refreshList()
end)

refreshList()
print("✅ Mob Puller đã load!")
