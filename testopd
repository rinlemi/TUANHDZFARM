-- Scan ALL items in backpack: every number-map category (Seeds, Gear...) + Pets + Fruits (Backpack tools)
local function scanAllItems()
    local groups = {}

    local function addToGroup(category, displayName, itemKey, qtyOrOne)
        local groupKey = category .. "|" .. displayName
        if not groups[groupKey] then
            groups[groupKey] = {
                Category = category,
                DisplayName = displayName,
                Available = 0,
                Sources = {},
            }
        end
        local g = groups[groupKey]
        g.Available = g.Available + qtyOrOne
        table.insert(g.Sources, {ItemKey = itemKey, Qty = qtyOrOne})
    end

    local inv = getInventory()

    -- 1) Auto-scan EVERY number-map category (Seeds, WateringCans, Sprinklers, Trowels, Crates, SeedPacks, Gnomes...)
    if inv then
        for catName, catData in pairs(inv) do
            if not EXCLUDED_CATEGORIES[catName] and type(catData) == "table" then
                local isNumberMap = true
                local hasEntry = false
                for _, v in pairs(catData) do
                    hasEntry = true
                    if type(v) ~= "number" then
                        isNumberMap = false
                        break
                    end
                end
                if isNumberMap and hasEntry then
                    for itemName, amount in pairs(catData) do
                        local qty = tonumber(amount) or 0
                        if qty > 0 then
                            addToGroup(catName, tostring(itemName), itemName, qty)
                        end
                    end
                end
            end
        end
    end

    -- 2) PETS from Inventory replica
    if inv and type(inv.Pets) == "table" then
        for petKey, petEntry in pairs(inv.Pets) do
            if type(petEntry) == "table" then
                local petName = tostring(petEntry.Name or petKey)
                addToGroup("Pets", petName, petKey, 1)
            end
        end
    end

    -- 3) FRUITS from Backpack (Tool with attribute HarvestedFruit = true)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local okAttr, attrs = pcall(function() return tool:GetAttributes() end)
                if okAttr and type(attrs) == "table" and attrs.HarvestedFruit == true then
                    local fruitName = tostring(attrs.FruitName or attrs.Fruit or tool.Name)
                    local id = attrs.Id or tool.Name
                    addToGroup("HarvestedFruits", fruitName, id, 1)
                end
            end
        end
    end

    local list = {}
    for _, g in pairs(groups) do
        table.insert(list, g)
    end
    table.sort(list, function(a, b)
        if a.Category ~= b.Category then return a.Category < b.Category end
        return a.DisplayName < b.DisplayName
    end)
    return list
end

local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then
        return false, "SendBatch not found"
    end
    local ok, result, message = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, payload, tostring(note or ""))
    end)
    if not ok then return false, "SendBatch error: " .. tostring(result) end
    if result == true then return true, tostring(message or "Gift sent!") end
    return false, tostring(message or "Failed to send gift")
end

-- Send selected groups. Server enforces a cooldown between gifts (~7s),
-- the script automatically waits and retries once if it hits "Wait Xs..."
-- Returns: totalSent, errorMsg, sentDetails (list of {Name, Qty})
local function sendSelectedGroups(userId, selections, note, statusCb)
    local allPayloadItems = {}
    local sentDetails = {} -- {DisplayName, Category, Qty} for the final notification

    for _, sel in ipairs(selections) do
        local group = sel.Group
        local needed = sel.RequestedQty
        if needed > 0 then
            if group.Category == "Pets" or group.Category == "HarvestedFruits" then
                local taken = 0
                for _, src in ipairs(group.Sources) do
                    if taken >= needed then break end
                    table.insert(allPayloadItems, {Category = group.Category, ItemKey = src.ItemKey, Count = 1})
                    taken = taken + 1
                end
                if taken > 0 then
                    table.insert(sentDetails, {Name = group.DisplayName, Qty = taken})
                end
            else
                local take = math.min(needed, group.Available)
                if take > 0 then
                    table.insert(allPayloadItems, {Category = group.Category, ItemKey = group.Sources[1].ItemKey, Count = take})
                    table.insert(sentDetails, {Name = group.DisplayName, Qty = take})
                end
            end
        end
    end

    if #allPayloadItems == 0 then
        return 0, "No items to send", {}
    end

    local totalSent = 0
    local batchSize = 20
    local i = 1
    local batchNum = 0
    while i <= #allPayloadItems do
        local batch = {}
        local j = i
        while j <= #allPayloadItems and #batch < batchSize do
            table.insert(batch, allPayloadItems[j])
            j = j + 1
        end

        batchNum = batchNum + 1
        if statusCb then statusCb("Sending batch " .. tostring(batchNum) .. "...") end

        local ok, msg = sendBatch(userId, batch, note)
        if ok then
            totalSent = totalSent + #batch
        else
            if tostring(msg):find("Wait") then
                if statusCb then statusCb("Waiting for server cooldown...") end
                task.wait(7.5)
                local ok2, msg2 = sendBatch(userId, batch, note)
                if ok2 then
                    totalSent = totalSent + #batch
                else
                    return totalSent, msg2, sentDetails
                end
            else
                return totalSent, msg, sentDetails
            end
        end

        i = j
        if i <= #allPayloadItems then
            task.wait(7.5)
        end
    end

    return totalSent, nil, sentDetails
end

-- ===================== AUTO CLAIM =====================
local function autoClaimAll(statusCb)
    if not Networking or not Networking.Mailbox then
        if statusCb then statusCb("Mailbox not found!") end
        return 0, 0
    end
    pcall(function() Networking.Mailbox.OpenInbox:Fire() end)
    task.wait(0.5)
    local ok, gifts = pcall(function() return Networking.Mailbox.List:Fire() end)
    if not ok or type(gifts) ~= "table" then
        if statusCb then statusCb("Could not load mailbox list!") end
        return 0, 0
    end
    local total = 0
    for _ in pairs(gifts) do total = total + 1 end
    if total == 0 then
        if statusCb then statusCb("Mailbox is empty!") end
        return 0, 0
    end
    local claimed = 0
    for giftId, giftData in pairs(gifts) do
        task.wait(0.35)
        if statusCb then statusCb("Claiming mail... " .. claimed .. "/" .. total) end
        local itemsTable = giftData.Items or giftData["Items table"]
        local ok2, result = pcall(function()
            return Networking.Mailbox.Claim:Fire(giftId, itemsTable)
        end)
        if ok2 and result then claimed = claimed + 1 end
    end
    task.wait(0.5)
    pcall(function() Networking.Mailbox.OpenInbox:Fire() end)
    return claimed, total
end

