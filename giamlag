end)

sendBtn.MouseButton1Click:Connect(function()
    if isSending or isClaiming then return end
    if not verifiedUserId then
        statusLbl.Text = "❌ Xác nhận người nhận trước!"; statusLbl.TextColor3 = C.red; return
    end

    -- Thu thập các item đã check
    local selections = {}
    for groupKey, st in pairs(selectedState) do
        if st.checked then
            local qty = tonumber(st.qtyBox.Text) or 0
            qty = math.floor(qty)
            if qty > 0 then
                table.insert(selections, {Group = st.group, RequestedQty = math.min(qty, st.group.Available)})
            end
        end
    end

    if #selections == 0 then
        statusLbl.Text = "❌ Chưa chọn item nào (tick checkbox + nhập số lượng)!"; statusLbl.TextColor3 = C.red; return
    end

    local note = noteBox.Text:match("^%s*(.-)%s*$")
    if note == "" then note = "auto-mail" end

    isSending = true
    sendBtn.Text = "⏳  Đang xử lý..."; sendBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    statusLbl.TextColor3 = C.yellow
    statusLbl.Text = "📦 Đang chuẩn bị gửi " .. tostring(#selections) .. " loại item..."

    task.spawn(function()
        local sent, err = sendSelectedGroups(verifiedUserId, selections, note, function(msg)
            statusLbl.Text = msg; statusLbl.TextColor3 = C.cyan
        end)

        if err then
            statusLbl.Text = "⚠ Đã gửi " .. sent .. " item | Lỗi: " .. tostring(err)
            statusLbl.TextColor3 = C.yellow
            notify("AutoMail", "Đã gửi " .. sent .. " item. Lỗi: " .. tostring(err), 6)
        else
            statusLbl.Text = "✅ Hoàn tất! Đã gửi " .. sent .. " item tới @" .. verifiedUsername
            statusLbl.TextColor3 = C.green
            notify("AutoMail", "✅ Đã gửi " .. sent .. " item tới @" .. verifiedUsername, 5)
        end

        isSending = false
        sendBtn.Text = "📬  GỬI ITEM ĐÃ CHỌN"; sendBtn.BackgroundColor3 = C.green
        refreshList()
    end)
end)

claimBtn.MouseButton1Click:Connect(function()
    if isClaiming or isSending then return end
    isClaiming = true
    claimBtn.Text = "⏳  Đang claim..."; claimBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    claimStatusLbl.Text = "⏳ Đang claim mail..."; claimStatusLbl.TextColor3 = C.yellow
    task.spawn(function()
        local claimed, total = autoClaimAll(function(msg)
            claimStatusLbl.Text = msg; claimStatusLbl.TextColor3 = C.yellow
        end)
        if total == 0 then
            claimStatusLbl.TextColor3 = C.muted
        elseif claimed >= total then
            claimStatusLbl.Text = "✅ Đã claim all mailbox! (" .. claimed .. "/" .. total .. ")"
            claimStatusLbl.TextColor3 = C.green
            notify("AutoClaim", "✅ Đã claim " .. claimed .. "/" .. total .. " mail!", 5)
        else
            claimStatusLbl.Text = "⚠ Claimed " .. claimed .. "/" .. total .. " mail"
            claimStatusLbl.TextColor3 = C.yellow
            notify("AutoClaim", "⚠ Claimed " .. claimed .. "/" .. total .. " mail", 5)
        end
        isClaiming = false
        claimBtn.Text = "📥  CLAIM ALL MAILBOX"; claimBtn.BackgroundColor3 = C.orange
        refreshList()
    end)
end)

