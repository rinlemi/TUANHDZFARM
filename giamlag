local SharedModules = ReplicatedStorage:WaitForChild("SharedModules")
local function safeRequire(inst)
    if not inst then return nil end
    local ok, result = pcall(require, inst)
    if ok then return result end
    return nil
end
local Networking = safeRequire(SharedModules:WaitForChild("Networking"))
local PlayerStateClient = safeRequire(ReplicatedStorage:WaitForChild("ClientModules"):WaitForChild("PlayerStateClient"))

local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title=title or "Mailbox", Text=text or "", Duration=duration or 4})
    end)
end

local function cleanUsername(name)
    name = tostring(name or "")
    name = name:gsub("^%s*@?", ""):gsub("%s+$", "")
    return name
end

local function lookupPlayer(username)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.LookupPlayer then
        return nil, "Không tìm thấy Networking.Mailbox.LookupPlayer"
    end
    local ok, userId, displayName = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if not ok or type(userId) ~= "number" or userId <= 0 then
        return nil, "Không tìm thấy người nhận: " .. tostring(username)
    end
    if userId == LocalPlayer.UserId then
        return nil, "Không thể gửi cho chính mình"
    end
    return userId, tostring(displayName or username)
end

local function waitLocalReplica(timeout)
    local replica = nil
    if PlayerStateClient and type(PlayerStateClient.WaitForLocalReplica) == "function" then
        local ok, result = pcall(function() return PlayerStateClient:WaitForLocalReplica(timeout or 30) end)
        if ok then replica = result end
    end
    if not replica and PlayerStateClient and type(PlayerStateClient.GetLocalReplica) == "function" then
        local started = os.clock()
        repeat
            local ok, result = pcall(function() return PlayerStateClient:GetLocalReplica() end)
            if ok and result then replica = result; break end
            task.wait(0.25)
        until os.clock() - started > (timeout or 30)
    end
    return replica
end

local function getInventory()
    local replica = waitLocalReplica(30)
    if not replica or type(replica.Data) ~= "table" or type(replica.Data.Inventory) ~= "table" then return nil end
    return replica.Data.Inventory
end

-- Quét toàn bộ item trong balo: Seeds (replica) + Pets (replica) + Fruit Tools (Backpack)
-- Trả về danh sách nhóm theo tên, mỗi nhóm có: Category, DisplayName, Available, Sources (list các ItemKey/Id cụ thể)
local function scanAllItems()
    local groups = {} -- key = Category.."|"..DisplayName

    local function addToGroup(category, displayName, itemKey, qtyOrOne)
        local groupKey = category .. "|" .. displayName
        if not groups[groupKey] then
            groups[groupKey] = {
                Category = category,
                DisplayName = displayName,
                Available = 0,
                Sources = {}, -- mỗi source: {ItemKey=.., Qty=..}
            }
        end
        local g = groups[groupKey]
        g.Available = g.Available + qtyOrOne
        table.insert(g.Sources, {ItemKey = itemKey, Qty = qtyOrOne})
    end

    -- 1) SEEDS từ Inventory replica (key = tên seed, value = số lượng number)
    local inv = getInventory()
    if inv and type(inv.Seeds) == "table" then
        for seedName, amount in pairs(inv.Seeds) do
            local qty = tonumber(amount) or 0
            if type(amount) == "table" then
                qty = tonumber(amount.Count or amount.Amount or amount.Quantity or amount.Stack or 0) or 0
            end
            if qty > 0 then
                addToGroup("Seeds", seedName, seedName, qty)
            end
        end
    end

    -- 2) PETS từ Inventory replica (key = Id, value = {Id, Equipped, Name})
    if inv and type(inv.Pets) == "table" then
        for petKey, petEntry in pairs(inv.Pets) do
            if type(petEntry) == "table" then
                local petName = tostring(petEntry.Name or petKey)
                addToGroup("Pets", petName, petKey, 1)
            end
        end
    end

    -- 3) FRUITS từ Backpack (Tool có attribute HarvestedFruit = true)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local attrs = tool:GetAttributes()
                if attrs and attrs.HarvestedFruit == true then
                    local fruitName = tostring(attrs.FruitName or attrs.Fruit or tool.Name)
                    local id = attrs.Id or tool.Name
                    addToGroup("HarvestedFruits", fruitName, id, 1)
                end
            end
        end
    end

    -- Chuyển dict thành list, sort theo Category rồi tên
    local list = {}
    for _, g in pairs(groups) do
        table.insert(list, g)
    end
    table.sort(list, function(a, b)
        if a.Category ~= b.Category then return a.Category < b.Category end
        return a.DisplayName < b.DisplayName
    end)
    return list
end

local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then
        return false, "Không tìm thấy SendBatch"
    end
    local ok, result, message = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, payload, tostring(note or ""))
    end)
    if not ok then return false, "SendBatch lỗi: " .. tostring(result) end
    if result == true then return true, tostring(message or "Đã gửi!") end
    return false, tostring(message or "Gửi thất bại")
end

-- Gửi nhiều nhóm item đã chọn, mỗi nhóm có Category/DisplayName/Sources/RequestedQty
-- Tự động chia batch tối đa 20 dòng payload mỗi lần gửi
local function sendSelectedGroups(userId, selections, note, statusCb)
    -- selections: list of {Group=group, RequestedQty=number}
    local allPayloadItems = {} -- mỗi item: {Category, ItemKey, Count}

    for _, sel in ipairs(selections) do
        local group = sel.Group
        local needed = sel.RequestedQty
        if needed > 0 then
            if group.Category == "Seeds" then
                -- Seeds: 1 ItemKey duy nhất, Count = số lượng
                local take = math.min(needed, group.Available)
                if take > 0 then
                    table.insert(allPayloadItems, {Category = "Seeds", ItemKey = group.Sources[1].ItemKey, Count = take})
                end
            else
                -- Pets / Fruits: mỗi instance Count = 1, lấy đủ số instance cần
                local taken = 0
                for _, src in ipairs(group.Sources) do
                    if taken >= needed then break end
                    table.insert(allPayloadItems, {Category = group.Category, ItemKey = src.ItemKey, Count = 1})
                    taken = taken + 1
                end
            end
        end
    end

    if #allPayloadItems == 0 then
        return 0, "Không có item nào để gửi"
    end

    local totalSent = 0
    local batchSize = 20
    local i = 1
    while i <= #allPayloadItems do
        local batch = {}
        local j = i
        while j <= #allPayloadItems and #batch < batchSize do
            table.insert(batch, allPayloadItems[j])
            j = j + 1
        end

        if statusCb then statusCb("📦 Đang gửi batch " .. tostring(math.ceil(i/batchSize)) .. "...") end

        local ok, msg = sendBatch(userId, batch, note)
        if ok then
            totalSent = totalSent + #batch
        else
            return totalSent, msg
        end

        i = j
        if i <= #allPayloadItems then
            task.wait(1.8)
        end
    end

    return totalSent, nil
end

-- ===================== AUTO CLAIM =====================
local function autoClaimAll(statusCb)
    if not Networking or not Networking.Mailbox then
        if statusCb then statusCb("❌ Không tìm thấy Mailbox!") end
        return 0, 0
    end
    pcall(function() Networking.Mailbox.OpenInbox:Fire() end)
    task.wait(0.5)
    local ok, gifts = pcall(function() return Networking.Mailbox.List:Fire() end)
    if not ok or type(gifts) ~= "table" then
        if statusCb then statusCb("❌ Không lấy được danh sách mail!") end
        return 0, 0
    end
    local total = 0
    for _ in pairs(gifts) do total = total + 1 end
    if total == 0 then
        if statusCb then statusCb("📭 Mailbox trống!") end
        return 0, 0
    end
    local claimed = 0
    for giftId, giftData in pairs(gifts) do
        task.wait(0.35)
        if statusCb then statusCb("⏳ Đang claim mail... " .. claimed .. "/" .. total) end
        local itemsTable = giftData.Items or giftData["Items table"]
        local ok2, result = pcall(function()
            return Networking.Mailbox.Claim:Fire(giftId, itemsTable)
        end)
        if ok2 and result then claimed = claimed + 1 end
    end
    task.wait(0.5)
    pcall(function() Networking.Mailbox.OpenInbox:Fire() end)
    return claimed, total
end

