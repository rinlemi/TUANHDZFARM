verifyBtn.MouseButton1Click:Connect(function()
    if isSending then return end
    local username = cleanUsername(recipientBox.Text)
    if username == "" then
        verifyStatus.Text = "❌ Nhập tên người nhận trước!"; verifyStatus.TextColor3 = C.red; return
    end
    verifyBtn.Text = "⏳  Đang tìm..."; verifyBtn.BackgroundColor3 = Color3.fromRGB(60,30,120)
    verifyStatus.Text = "Đang xác nhận..."; verifyStatus.TextColor3 = C.yellow
    task.spawn(function()
        local userId, displayName = lookupPlayer(username)
        if userId then
            verifiedUserId = userId; verifiedUsername = username
            verifyStatus.Text = "✅ Tìm thấy: @" .. username .. " [" .. tostring(userId) .. "]"
            verifyStatus.TextColor3 = C.green
            recipientFrame.BackgroundColor3 = Color3.fromRGB(14,36,22)
            stroke(recipientFrame, C.green, 1)
        else
            verifiedUserId = nil; verifiedUsername = nil
            verifyStatus.Text = "❌ " .. tostring(displayName)
            verifyStatus.TextColor3 = C.red
            recipientFrame.BackgroundColor3 = C.card
            stroke(recipientFrame, C.red, 1)
        end
        verifyBtn.Text = "🔍  Xác Nhận Người Nhận"; verifyBtn.BackgroundColor3 = C.accent
    end)
end)

recipientBox:GetPropertyChangedSignal("Text"):Connect(function()
    verifiedUserId = nil; verifiedUsername = nil
