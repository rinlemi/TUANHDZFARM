local function buildItemRow(group, order)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-10,0,30)
    row.BackgroundColor3 = C.card; row.BorderSizePixel = 0
    row.LayoutOrder = order
    corner(6, row)
    stroke(row, C.border, 1)

    local checkBtn = Instance.new("TextButton", row)
    checkBtn.Size = UDim2.new(0,22,0,22); checkBtn.Position = UDim2.new(0,4,0.5,-11)
    checkBtn.BackgroundColor3 = Color3.fromRGB(45,45,70); checkBtn.BorderSizePixel = 0
    checkBtn.Text = ""; corner(5, checkBtn); stroke(checkBtn, C.border, 1)

    local checkMark = Instance.new("TextLabel", checkBtn)
    checkMark.Size = UDim2.new(1,0,1,0); checkMark.BackgroundTransparency = 1
    checkMark.Text = ""; checkMark.TextColor3 = Color3.fromRGB(10,10,10)
    checkMark.TextSize = 14; checkMark.Font = Enum.Font.GothamBold

    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.Size = UDim2.new(1,-150,1,0); nameLbl.Position = UDim2.new(0,32,0,0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = group.DisplayName .. " (x" .. tostring(group.Available) .. ")"
    nameLbl.TextColor3 = C.white; nameLbl.TextSize = 11; nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

    local catTag = Instance.new("TextLabel", row)
    catTag.Size = UDim2.new(0,60,0,14); catTag.Position = UDim2.new(1,-148,0.5,-7)
    catTag.BackgroundTransparency = 1
    catTag.Text = group.Category == "Seeds" and "🌱Seed" or (group.Category == "Pets" and "🐾Pet" or "🍎Fruit")
    catTag.TextColor3 = C.muted; catTag.TextSize = 8; catTag.Font = Enum.Font.Gotham
    catTag.TextXAlignment = Enum.TextXAlignment.Left

    local qtyFrame = Instance.new("Frame", row)
    qtyFrame.Size = UDim2.new(0,70,0,22); qtyFrame.Position = UDim2.new(1,-76,0.5,-11)
    qtyFrame.BackgroundColor3 = Color3.fromRGB(45,45,70); qtyFrame.BorderSizePixel = 0; corner(5, qtyFrame)
    local qtyBox = Instance.new("TextBox", qtyFrame)
    qtyBox.Size = UDim2.new(1,-8,1,0); qtyBox.Position = UDim2.new(0,4,0,0)
    qtyBox.BackgroundTransparency = 1; qtyBox.Text = tostring(math.min(1, group.Available))
    qtyBox.TextColor3 = C.white; qtyBox.TextSize = 10; qtyBox.Font = Enum.Font.GothamBold
    qtyBox.ClearTextOnFocus = false; qtyBox.TextXAlignment = Enum.TextXAlignment.Center

    local groupKey = group.Category .. "|" .. group.DisplayName
    selectedState[groupKey] = {checked = false, qtyBox = qtyBox, group = group}

    checkBtn.MouseButton1Click:Connect(function()
        local st = selectedState[groupKey]
        st.checked = not st.checked
        if st.checked then
            checkBtn.BackgroundColor3 = C.checkOn
            checkMark.Text = "✓"
            stroke(checkBtn, C.checkOn, 1)
        else
            checkBtn.BackgroundColor3 = Color3.fromRGB(45,45,70)
            checkMark.Text = ""
            stroke(checkBtn, C.border, 1)
        end
    end)

    return row
end

local function refreshList()
    for _, child in ipairs(listFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    selectedState = {}
    currentGroups = scanAllItems()

    if #currentGroups == 0 then
        local emptyLbl = Instance.new("TextLabel", listFrame)
        emptyLbl.Size = UDim2.new(1,-10,0,30)
        emptyLbl.BackgroundTransparency = 1
        emptyLbl.Text = "📭 Balo trống hoặc chưa đọc được dữ liệu"
        emptyLbl.TextColor3 = C.muted; emptyLbl.TextSize = 10; emptyLbl.Font = Enum.Font.Gotham
        return
    end

    for i, group in ipairs(currentGroups) do
        buildItemRow(group, i)
    end

    task.wait()
    listFrame.CanvasSize = UDim2.new(0,0,0, listLayout.AbsoluteContentSize.Y + 12)
end

refreshBtn.MouseButton1Click:Connect(function()
    refreshBtn.Text = "⏳..."
    refreshList()
    refreshBtn.Text = "🔄 Refresh"
end)

