sendBtn.MouseButton1Click:Connect(function()
    if isSending then return end

    -- Validate
    if not verifiedUserId then
        statusLbl.Text = "❌ Xác nhận người nhận trước!"; statusLbl.TextColor3 = C.red; return
    end
    local itemName = itemBox.Text:match("^%s*(.-)%s*$")
    if itemName == "" then
        statusLbl.Text = "❌ Nhập tên item!"; statusLbl.TextColor3 = C.red; return
    end
    local qty = tonumber(qtyBox.Text)
    if not qty or qty <= 0 then
        statusLbl.Text = "❌ Số lượng không hợp lệ!"; statusLbl.TextColor3 = C.red; return
    end
    qty = math.floor(qty)
    local note = noteBox.Text:match("^%s*(.-)%s*$")
    if note == "" then note = "auto-mail" end

    isSending = true
    sendBtn.Text = "⏳  Đang xử lý..."; sendBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    statusLbl.TextColor3 = C.yellow

    task.spawn(function()
        -- Đọc inventory
        statusLbl.Text = "📂 Đang đọc inventory..."
        local inv = getInventory()
        if not inv then
            statusLbl.Text = "❌ Không đọc được inventory!"; statusLbl.TextColor3 = C.red
            isSending = false; sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green; return
        end

        -- Tìm item
        statusLbl.Text = "🔍 Đang tìm item: " .. itemName
        local items = findItems(itemName, inv)
        if #items == 0 then
            statusLbl.Text = "❌ Không tìm thấy item: " .. itemName; statusLbl.TextColor3 = C.red
            isSending = false; sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green; return
        end

        -- Tính tổng available
        local totalAvailable = 0
        for _, item in ipairs(items) do totalAvailable += item.Available end
        local toSend = math.min(qty, totalAvailable)
        if toSend < qty then
            statusLbl.Text = "⚠ Chỉ có " .. toSend .. "/" .. qty .. " item. Gửi hết số có sẵn..."
            statusLbl.TextColor3 = C.yellow
            task.wait(1.5)
        end

        -- Gửi
        local batches = math.ceil(toSend / 20)
        statusLbl.Text = "📦 Cần gửi " .. toSend .. " item (" .. batches .. " batch)..."
        statusLbl.TextColor3 = C.cyan

        local sent, err = sendAll(verifiedUserId, items, toSend, note, function(msg)
            statusLbl.Text = msg; statusLbl.TextColor3 = C.cyan
        end)

        if err then
            statusLbl.Text = "⚠ Đã gửi " .. sent .. "/" .. toSend .. " | Lỗi: " .. tostring(err)
            statusLbl.TextColor3 = C.yellow
            notify("AutoMail", "Đã gửi " .. sent .. "/" .. toSend .. " item. Lỗi: " .. err, 6)
        else
            statusLbl.Text = "✅ Hoàn tất! Đã gửi " .. sent .. " item tới @" .. verifiedUsername
            statusLbl.TextColor3 = C.green
            notify("AutoMail", "✅ Đã gửi " .. sent .. " item tới @" .. verifiedUsername, 5)
        end

        isSending = false
        sendBtn.Text = "📬  GỬI NGAY"; sendBtn.BackgroundColor3 = C.green
    end)
end)

