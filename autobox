-- ===================== SETUP =====================
local SharedModules = ReplicatedStorage:WaitForChild("SharedModules")
local SharedData = ReplicatedStorage:WaitForChild("SharedData")
local function safeRequire(inst)
    if not inst then return nil end
    local ok, result = pcall(require, inst)
    if ok then return result end
    return nil
end
local Networking = safeRequire(SharedModules:WaitForChild("Networking"))
local PlayerStateClient = safeRequire(ReplicatedStorage:WaitForChild("ClientModules"):WaitForChild("PlayerStateClient"))

local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title=title or "Mailbox", Text=text or "", Duration=duration or 4})
    end)
end

local function cleanUsername(name)
    name = tostring(name or "")
    name = name:gsub("^%s*@?", ""):gsub("%s+$", "")
    return name
end

local function resolveUsernameFromUserId(userId)
    if type(userId) ~= "number" or userId <= 0 then return nil end
    local ok, result = pcall(function() return Players:GetNameFromUserIdAsync(userId) end)
    if ok and type(result) == "string" and result ~= "" then return result end
    return nil
end

local function lookupPlayer(username)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.LookupPlayer then
        return nil, "Không tìm thấy Networking.Mailbox.LookupPlayer"
    end
    local ok, userId, displayName = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if not ok or type(userId) ~= "number" or userId <= 0 then
        return nil, "Không tìm thấy người nhận: " .. tostring(username)
    end
    if userId == LocalPlayer.UserId then
        return nil, "Không thể gửi cho chính mình"
    end
    return userId, tostring(displayName or username)
end

local function waitLocalReplica(timeout)
    local replica = nil
    if type(PlayerStateClient.WaitForLocalReplica) == "function" then
        local ok, result = pcall(function() return PlayerStateClient:WaitForLocalReplica(timeout or 30) end)
        if ok then replica = result end
    end
    if not replica and type(PlayerStateClient.GetLocalReplica) == "function" then
        local started = os.clock()
        repeat
            local ok, result = pcall(function() return PlayerStateClient:GetLocalReplica() end)
            if ok and result then replica = result; break end
            task.wait(0.25)
        until os.clock() - started > (timeout or 30)
    end
    return replica
end

local function getInventory()
    local replica = waitLocalReplica(30)
    if not replica or type(replica.Data) ~= "table" or type(replica.Data.Inventory) ~= "table" then return nil end
    return replica.Data.Inventory
end

-- Tìm item trong inventory theo tên (seed, fruit, pet)
local function findItems(itemName, inv)
    local results = {}
    local searchNorm = string.lower(itemName:gsub("%s+",""))

    -- Scan Seeds
    if type(inv.Seeds) == "table" then
        for seedKey, seedEntry in pairs(inv.Seeds) do
            local keyNorm = string.lower(tostring(seedKey):gsub("%s+",""))
            local amount = 0
            if type(seedEntry) == "table" then
                amount = tonumber(seedEntry.Count or seedEntry.Amount or seedEntry.Quantity or seedEntry.Stack or 0) or 0
            elseif type(seedEntry) == "number" then
                amount = seedEntry
            end
            if keyNorm:find(searchNorm, 1, true) or searchNorm:find(keyNorm, 1, true) then
                if amount > 0 then
                    table.insert(results, {Category="Seeds", ItemKey=seedKey, Available=amount, DisplayName=seedKey})
                end
            end
        end
    end

    -- Scan HarvestedFruits
    if type(inv.HarvestedFruits) == "table" then
        for itemKey, entry in pairs(inv.HarvestedFruits) do
            if type(entry) == "table" and entry.Id ~= nil then
                local name = tostring(entry.FruitName or entry.Name or entry.DisplayName or itemKey)
                local nameNorm = string.lower(name:gsub("%s+",""))
                if nameNorm:find(searchNorm, 1, true) or searchNorm:find(nameNorm, 1, true) then
                    table.insert(results, {Category="HarvestedFruits", ItemKey=itemKey, Available=1, DisplayName=name})
                end
            end
        end
    end

    -- Scan Pets
    if type(inv.Pets) == "table" then
        for itemKey, entry in pairs(inv.Pets) do
            if type(entry) == "table" and entry.Id ~= nil then
                local name = tostring(entry.Name or entry.PetName or entry.Species or entry.DisplayName or itemKey)
                local nameNorm = string.lower(name:gsub("%s+",""))
                if nameNorm:find(searchNorm, 1, true) or searchNorm:find(nameNorm, 1, true) then
                    table.insert(results, {Category="Pets", ItemKey=itemKey, Available=1, DisplayName=name})
                end
            end
        end
    end

    return results
end

local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then
        return false, "Không tìm thấy SendBatch"
    end
    local ok, result, message = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, payload, tostring(note or ""))
    end)
    if not ok then return false, "SendBatch lỗi: " .. tostring(result) end
    if result == true then return true, tostring(message or "Đã gửi!") end
    return false, tostring(message or "Gửi thất bại")
end

-- Gửi nhiều lần nếu số lượng > 20
local function sendAll(userId, items, totalNeeded, note, statusCb)
    local MAX_PER_BATCH = 20
    local sent = 0
    local remaining = totalNeeded
    local itemIndex = 1
    local itemSentCount = 0

    while remaining > 0 and itemIndex <= #items do
        local batch = {}
        local batchCount = 0

        while batchCount < MAX_PER_BATCH and remaining > 0 and itemIndex <= #items do
            local item = items[itemIndex]
            local canTake = math.min(item.Available - itemSentCount, remaining, MAX_PER_BATCH - batchCount)
            if canTake <= 0 then
                itemIndex += 1
                itemSentCount = 0
            else
                table.insert(batch, {Category=item.Category, ItemKey=item.ItemKey, Count=canTake})
                batchCount += canTake
                itemSentCount += canTake
                remaining -= canTake
                if itemSentCount >= item.Available then
                    itemIndex += 1
                    itemSentCount = 0
                end
            end
        end

        if #batch > 0 then
            if statusCb then statusCb("📦 Đang gửi batch " .. tostring(math.ceil((sent+batchCount)/MAX_PER_BATCH)) .. "... (" .. tostring(sent) .. "/" .. tostring(totalNeeded) .. ")") end
            local ok, msg = sendBatch(userId, batch, note)
            if ok then
                sent += batchCount
                if statusCb then statusCb("✅ Đã gửi " .. tostring(sent) .. "/" .. tostring(totalNeeded)) end
            else
                if statusCb then statusCb("❌ Lỗi batch: " .. tostring(msg)) end
                return sent, msg
            end
            task.wait(1.8)
        else
            break
        end
    end

    return sent, nil
end

