        for _,v in ipairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        local count=0
        local char=player.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("Tool") and v.Name:find("Fruit") then
                local handle=v:FindFirstChild("Handle")
                if handle then
                    count+=1
                    local dist=hrp and math.floor((hrp.Position-handle.Position).Magnitude) or 0
                    local row=Instance.new("Frame",scroll); row.Size=UDim2.new(1,0,0,28); row.BackgroundColor3=C.card; row.BorderSizePixel=0; corner(5,row)
