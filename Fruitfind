                    rbtn.MouseButton1Click:Connect(function()
                        local c=player.Character; if not c then return end
                        local h=c:FindFirstChild("HumanoidRootPart"); if not h then return end
                        local d=(h.Position-capturedPos).Magnitude
                        local tw=TweenService:Create(h,TweenInfo.new(d/1000,Enum.EasingStyle.Linear),{CFrame=CFrame.new(capturedPos+Vector3.new(0,5,0))})
                        tw:Play()
                        row.BackgroundColor3=C.selBg; lbl.TextColor3=C.orange
                    end)
                end
            end
        end
        countLbl.Text="🍎 Fruits: "..count
        scroll.CanvasSize=UDim2.new(0,0,0,ll.AbsoluteContentSize.Y+10)
    end
    refreshBtn.MouseButton1Click:Connect(function()
        refreshBtn.Text="⏳"; refreshFruits(); task.delay(0.4,function() refreshBtn.Text="🔄 Refresh" end)
    end)
    -- Auto refresh khi mở tab
    tabs["TP Fruit"].btn.MouseButton1Click:Connect(function() refreshFruits() end)
    refreshFruits()
end

