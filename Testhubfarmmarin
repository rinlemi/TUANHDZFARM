-- HELPERS
local function getChar() return player.Character or player.CharacterAdded:Wait() end
local function getHRP() return getChar():FindFirstChild("HumanoidRootPart") end

local function setStatus(text, color)
	statusLabel.Text = text
	statusLabel.TextColor3 = color or Color3.fromRGB(180,180,180)
end

local function getWave()
	local raidGui = player.PlayerGui:FindFirstChild("Raid")
	if not raidGui then return 0, 0 end
	local frame = raidGui:FindFirstChild("Frame")
	if not frame then return 0, 0 end
	local w = frame:FindFirstChild("Wave")
	local e = frame:FindFirstChild("Enemies")
	local wave = w and tonumber(w.Text:match("%d+")) or 0
	local mobs = e and tonumber(e.Text:match("%d+")) or 0
	return wave, mobs
end

local function stopNormalThreads()
	for _, t in ipairs(normalThreads) do
		pcall(function() task.cancel(t) end)
	end
	normalThreads = {}
end

local function tweenTo(pos, duration)
	local hrp = getHRP()
	if not hrp then return end
	local tw = TweenService:Create(hrp,
		TweenInfo.new(duration or 1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{CFrame = CFrame.new(pos)}
	)
	tw:Play()
	tw.Completed:Wait()
end

local function tpTo(pos)
	local hrp = getHRP()
	if hrp then hrp.CFrame = CFrame.new(pos) end
end

-- ✅ AUTO HAKI CHECK (method mới)
local function IsHakiOn()
	local char = getChar()
	local arm = char:FindFirstChild("Right Arm")
	if not arm then return false end
	return arm.Transparency == 1
end

-- ✅ AUTO MAGMA2 CHECK (method mới)
local function IsMagmaOn()
	local char = getChar()
	local arm = char:FindFirstChild("Right Arm")
	if not arm then return false end
	local c = arm.Color
	return c.R > 0.5 and c.G < 0.3 and c.B < 0.3
end

local function UseMagma2()
	local char = getChar()
	pcall(function()
		char:WaitForChild("Powers")
			:WaitForChild("Magma")
			:WaitForChild("RemoteEvent")
			:FireServer("MagmaPower2")
	end)
end

local function UseHaki()
	pcall(function()
		workspace:WaitForChild("UserData")
			:WaitForChild(userFolder)
			:WaitForChild("UpdateHaki")
			:FireServer()
	end)
end

-- ✅ Thread tự động giữ Haki + Magma2 luôn bật
local function startAutoBuffs()
	if autoBuffThread then
		pcall(function() task.cancel(autoBuffThread) end)
	end
	autoBuffThread = task.spawn(function()
		while farming do
			if not IsHakiOn() then
				UseHaki()
				print("🔵 Bật Haki")
			end
			if not IsMagmaOn() then
				UseMagma2()
				print("🔥 Bật Magma2")
			end
			task.wait(1)
		end
	end)
end

local function stopAutoBuffs()
	if autoBuffThread then
		pcall(function() task.cancel(autoBuffThread) end)
		autoBuffThread = nil
	end
end

