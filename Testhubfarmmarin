-- ===================== WAVE THƯỜNG =====================
local normalThreads = {}

local function stopNormalThreads()
	for _, t in ipairs(normalThreads) do
		pcall(function() task.cancel(t) end)
	end
	normalThreads = {}
end

local function startNormalWave()
	stopNormalThreads()
	setStatus("🌊 Wave thường - Lên trời", Color3.fromRGB(0,200,255))

	-- Tween lên trời
	tweenTo(SKY_POS, 1.5)

	-- Giữ vị trí trên trời
	table.insert(normalThreads, startHoldPos(SKY_POS))

	-- Spam Aqua Staff
	table.insert(normalThreads, startStaffSpam())

	-- Kéo mob
	table.insert(normalThreads, startPullMobs())

	-- Haki watcher
	table.insert(normalThreads, startHakiWatcher())

	-- Magma2 watcher
	table.insert(normalThreads, startMagma2Watcher())
end

-- ===================== WAVE BOSS =====================
local function doBossWave(bossName)
	-- Dừng pull mob và normal threads
	stopNormalThreads()
	setStatus("⏳ Chờ "..bossName.." spawn...", Color3.fromRGB(255,200,0))

	-- Chờ boss spawn thật sự
	local spawned = waitForBossSpawn(bossName)
	if not spawned then
		setStatus("❌ Boss không spawn!", Color3.fromRGB(255,0,0))
		return
	end

	setStatus("👹 Boss: "..bossName, Color3.fromRGB(255,100,0))
	createStandParts()

	-- Spam staff vẫn chạy
	local staffThread = startStaffSpam()

	-- Haki watcher
	local hakiThread = startHakiWatcher()

	-- Loop đánh boss
	while farming and isBossAlive(bossName) do
		-- Tween 4 điểm
		for _, pos in ipairs(BOSS_POINTS) do
			if not farming or not isBossAlive(bossName) then break end
			tweenTo(pos, 0.5)
			useMagma4OnBoss(bossName)
			task.wait(0.2)
		end

		if not farming or not isBossAlive(bossName) then break end

		-- Xuống điểm 5
		tweenTo(BOSS_GROUND, 0.5)
		useMagma3()
		task.wait(0.3)
	end

	-- Dừng threads boss
	pcall(function() task.cancel(staffThread) end)
	pcall(function() task.cancel(hakiThread) end)

	removeStandParts()
	setStatus("✅ "..bossName.." đã chết!", Color3.fromRGB(0,255,100))
	task.wait(1)
end

-- ===================== WAVE 15 QUAKEBOSS =====================
local function doQuakeBoss()
	stopNormalThreads()
	setStatus("⏳ Chờ QuakeBoss spawn...", Color3.fromRGB(255,200,0))

	local spawned = waitForBossSpawn("QuakeBoss")
	if not spawned then
		setStatus("❌ QuakeBoss không spawn!", Color3.fromRGB(255,0,0))
		return
	end

	setStatus("💥 QuakeBoss!", Color3.fromRGB(255,50,50))

	-- TP đến điểm
	tpTo(WAVE15_POS)
	task.wait(2)

	-- Freeze nhân vật
	local hrp = getHRP()
	if hrp then hrp.Anchored = true end

	-- Spam skills
	local staffThread = startStaffSpam()
	local hakiThread = startHakiWatcher()

	local skillThread = task.spawn(function()
		while farming and isBossAlive("QuakeBoss") do
			useMagma4OnBoss("QuakeBoss")
			task.wait(0.1)
			useMagma3()
			task.wait(0.1)
		end
	end)

	-- Chờ boss chết
	repeat task.wait(0.5) until not isBossAlive("QuakeBoss") or not farming

	-- Dừng và unfreeze
	pcall(function() task.cancel(staffThread) end)
	pcall(function() task.cancel(hakiThread) end)
	pcall(function() task.cancel(skillThread) end)
	if hrp then hrp.Anchored = false end

	setStatus("✅ QuakeBoss đã chết!", Color3.fromRGB(0,255,100))
	task.wait(1)
end

-- ===================== MAIN LOOP =====================
local function startFarm()
	farming = true
	startBtn.Text = "⏹ Dừng"
	startBtn.BackgroundColor3 = Color3.fromRGB(180,0,0)
	setStatus("🚀 Bắt đầu farm!", Color3.fromRGB(0,255,100))

	-- Update display
	task.spawn(function()
		while farming do
			local w, m = getWave()
			waveLabel.Text = "Wave: "..w
			mobLabel.Text = "Mob: "..m
			task.wait(0.5)
		end
	end)

	task.spawn(function()
		local lastWave = 0

		while farming do
			local wave, mobs = getWave()

			-- Chờ raid bắt đầu
			if wave == 0 then
				setStatus("⏳ Chờ raid bắt đầu...", Color3.fromRGB(200,200,0))
				task.wait(1)
				continue
			end

			-- Wave mới
			if wave ~= lastWave then
				lastWave = wave
				stopNormalThreads()

				if wave == 5 then
					doBossWave("ChillyBoss")
					-- Sau boss tween xuống đất nhẹ
					tweenTo(GROUND_POS, 2)
				elseif wave == 10 then
					doBossWave("MagmaBoss")
					tweenTo(GROUND_POS, 2)
				elseif wave == 15 then
					doQuakeBoss()
				else
					startNormalWave()
				end
			end

			-- Theo dõi mob về 0 để chuyển wave (chỉ wave thường)
			if wave ~= 5 and wave ~= 10 and wave ~= 15 then
				if mobs <= 0 then
					-- Tween xuống đất nhẹ nhàng
					stopNormalThreads()
					setStatus("✅ Wave "..wave.." xong! Chờ wave tiếp...", Color3.fromRGB(0,255,100))
					tweenTo(GROUND_POS, 2)
					-- Chờ wave mới
					repeat
						task.wait(0.5)
						local newWave, _ = getWave()
						if not farming then break end
					until newWave > wave
				end
			end

			task.wait(0.5)
		end
	end)
end

local function stopFarm()
	farming = false
	stopNormalThreads()
	removeStandParts()
	local hrp = getHRP()
	if hrp then hrp.Anchored = false end
	startBtn.Text = "▶ Bắt đầu Farm"
	startBtn.BackgroundColor3 = Color3.fromRGB(0,140,0)
	setStatus("⏹ Đã dừng", Color3.fromRGB(180,180,180))
	waveLabel.Text = "Wave: --"
	mobLabel.Text = "Mob: --"
end

startBtn.MouseButton1Click:Connect(function()
	if farming then stopFarm() else startFarm() end
end)

print("✅ Auto Farm Marine Raid đã load!")
