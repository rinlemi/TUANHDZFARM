					-0.48251354694366455, 0.21727077662944794, -0.8485128283500671,
					-0, 0.968745231628418, 0.24805757403373718,
					0.8758885264396667, 0.1196911409497261, -0.4674326777458191
				),
				part
			)
	end)
end

local function useMagma2()
	local char = getChar()
	pcall(function()
		char:WaitForChild("Powers"):WaitForChild("Magma")
			:WaitForChild("RemoteEvent"):FireServer("MagmaPower2")
	end)
end

local function useMagma3()
	local part = workspace:FindFirstChild("Part", true)
	if part then
		local char = getChar()
		pcall(function()
			char.Powers.Magma.RemoteEvent:FireServer("MagmaPower3","Create",part.CFrame,part)
		end)
	end
end

local function useMagma4OnBoss(bossName)
	local e = workspace.Enemies:FindFirstChild(bossName)
	if e and e:FindFirstChild("HumanoidRootPart") and e.Humanoid.Health > 0 then
		local char = getChar()
		pcall(function()
			char.Powers.Magma.RemoteEvent:FireServer(
				"MagmaPower4","Create",
				e.HumanoidRootPart.CFrame,
				e:FindFirstChild("Left Arm") or e.HumanoidRootPart
			)
		end)
	end
end

-- ✅ MagmaPower1 quăng vào boss mỗi 5 giây
local function startMagma1OnBoss(bossName)
	return task.spawn(function()
		while farming and isBossAlive(bossName) do
			local mob = workspace.Enemies:FindFirstChild(bossName)
			if mob and mob:FindFirstChild("WeldToHead") then
				pcall(function()
					player.Character.Powers.Magma.RemoteEvent:FireServer(
						"MagmaPower1",
						"StopCharging",
						mob.WeldToHead.CFrame,
						mob.WeldToHead,
						"Right"
					)
				end)
				print("🌋 MagmaPower1 → "..bossName)
			end
			task.wait(5)
		end
	end)
end

local function pullMobs()
	local hrp = getHRP()
	if not hrp then return end
	for _, mob in ipairs(workspace.Enemies:GetChildren()) do
		local mobHrp = mob:FindFirstChild("HumanoidRootPart")
		local hum = mob:FindFirstChild("Humanoid")
		if mobHrp and hum and hum.Health > 0 then
			local ai = mob:FindFirstChild("AI") or mob:FindFirstChild("AIGun")
			if ai then ai.Disabled = true end
			mobHrp.Anchored = true
			mobHrp.CFrame = hrp.CFrame
		end
	end
end

local function equipAquaStaff()
	local char = getChar()
	if char:FindFirstChild("Aqua Staff") then return end
	local vrs = game:GetService("VirtualInputManager")
	vrs:SendKeyEvent(true, Enum.KeyCode.Three, false, game)
	task.wait(0.1)
	vrs:SendKeyEvent(false, Enum.KeyCode.Three, false, game)
	task.wait(0.3)
end

local function isBossAlive(bossName)
	local boss = workspace.Enemies:FindFirstChild(bossName)
	return boss and boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0
end

local function waitForBossSpawn(bossName)
	setStatus("⏳ Chờ "..bossName.." spawn...", Color3.fromRGB(255,200,0))
	local t = 0
	repeat
		task.wait(0.5)
		t = t + 0.5
		if not farming then return false end
	until isBossAlive(bossName) or t >= 30
	return isBossAlive(bossName)
end

