--// ONE PIECE FINAL - FARM SCRIPT
--// Auto Click (method mới) + Auto Z + Auto Chest + Server Hop

local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local VIM = VirtualInputManager

local player = Players.LocalPlayer

-- ===================== AUTO CLICK (Method mới - tìm nút Spawn/เลือก) =====================
local function clickGui(gui)
	local pos = gui.AbsolutePosition
	local size = gui.AbsoluteSize
	local x = pos.X + size.X / 2
	local y = pos.Y + size.Y / 2 + 50
	print("Click:", gui.Text, x, y)
	VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
	task.wait(0.05)
	VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

task.spawn(function()
	while task.wait(0.2) do
		for _, v in ipairs(player.PlayerGui:GetDescendants()) do
			if v:IsA("TextButton") and v.Visible then
				local txt = string.lower(v.Text)
				if txt == "spawn" or v.Text == "เลือก" then
					print("✅ Found Button:", v.Text)
					clickGui(v)
					task.wait(2)
				end
			end
		end
	end
end)

-- ===================== AUTO Z (Tự bật lại khi tắt) =====================
local function pressZ()
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
	task.wait(0.1)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
end

task.spawn(function()
	while task.wait(1) do
		local char = player.Character
		if char then
			local invisible = char:GetAttribute("Invisible")
			if not invisible then
				pressZ()
			end
		end
	end
end)

-- ===================== SERVER HOP =====================
local function hopServer()
	print("🔍 Tìm server mới...")
	local gameId = game.PlaceId
	local ok, result = pcall(function()
		return HttpService:JSONDecode(game:HttpGetAsync(
			("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100"):format(gameId)
		))
	end)
	if not ok then warn("❌ Lỗi:", result) return end
	for _, server in ipairs(result.data) do
		if server.playing >= 9
			and server.playing < server.maxPlayers
			and server.id ~= game.JobId then
			print("➡️ Hop:", server.id, "| Người:", server.playing)
			TeleportService:TeleportToPlaceInstance(gameId, server.id, player)
			return
		end
	end
	warn("❌ Không tìm được server!")
end

-- ===================== AUTO CHEST (Bay lên +400 rồi hạ xuống) =====================
local function tweenToChest(chest)
	local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local ok, targetPos = pcall(function() return chest:GetPivot().Position end)
	if not ok or not chest.Parent then return end
	local startPos = hrp.Position

	-- Bay lên cao +400
	local upPos = Vector3.new(startPos.X, startPos.Y + 400, startPos.Z)
	local tw0 = TweenService:Create(hrp,
		TweenInfo.new(0.15, Enum.EasingStyle.Linear),
		{CFrame = CFrame.new(upPos)}
	)
	tw0:Play()
	tw0.Completed:Wait()

	-- Hạ xuống chest
	if not chest.Parent then return end
	local tw1 = TweenService:Create(hrp,
		TweenInfo.new(0.15, Enum.EasingStyle.Linear),
		{CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))}
	)
	tw1:Play()
	tw1.Completed:Wait()

	task.wait(0.2)
	print("✅ Nhặt chest!")
end

local function getAllChests()
	local chests = {}
	for _, v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v.Name == "TreasureChest" then
			table.insert(chests, v)
		end
	end
	return chests
end

local function collectAllChests()
	local chests = getAllChests()
	print("🎁 Tìm thấy", #chests, "chest!")
	if #chests == 0 then
		print("❌ Không có chest! Hop server...")
		task.wait(1)
		hopServer()
		return
	end
	for _, chest in ipairs(chests) do
		if chest and chest.Parent then
			tweenToChest(chest)
		end
	end
	task.wait(1)
	local remaining = getAllChests()
	if #remaining == 0 then
		print("🏃 Hết chest! Hop server...")
		task.wait(1)
		hopServer()
	else
		print("🎁 Còn", #remaining, "chest! Nhặt tiếp...")
		collectAllChests()
	end
end

-- Detect chest mới spawn
workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("Model") and obj.Name == "TreasureChest" then
		task.wait(0.3)
		tweenToChest(obj)
	end
end)

