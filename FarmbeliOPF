local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local function hopServer()
    print("🔍 Tìm server mới...")
    local gameId = game.PlaceId
    local ok, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGetAsync(
            ("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100"):format(gameId)
        ))
    end)
    if not ok then warn("❌ Lỗi:", result) return end
    for _, server in ipairs(result.data) do
        if server.playing >= 9
        and server.playing < server.maxPlayers
        and server.id ~= game.JobId then
            print("➡️ Hop:", server.id, "| Người:", server.playing)
            TeleportService:TeleportToPlaceInstance(gameId, server.id, player)
            return
        end
    end
    warn("❌ Không tìm được server!")
end

local function tweenToChestUnderground(chest)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local ok, targetPos = pcall(function() return chest:GetPivot().Position end)
    if not ok or not chest.Parent then return end

    local startPos = hrp.Position
    local midPos = Vector3.new(
        (startPos.X + targetPos.X) / 2,
        startPos.Y - 100,
        (startPos.Z + targetPos.Z) / 2
    )

    local tw1 = TweenService:Create(hrp,
        TweenInfo.new(0.15, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(midPos)}
    )
    tw1:Play()
    tw1.Completed:Wait()

    if not chest.Parent then return end

    local tw2 = TweenService:Create(hrp,
        TweenInfo.new(0.15, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))}
    )
    tw2:Play()
    tw2.Completed:Wait()

    task.wait(0.2)
    print("✅ Nhặt chest!")
end

local function getAllChests()
    local chests = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == "TreasureChest" then
            table.insert(chests, v)
        end
    end
    return chests
end

local function collectAllChests()
    local chests = getAllChests()
    print("🎁 Tìm thấy", #chests, "chest!")

    if #chests == 0 then
        print("❌ Không có chest! Hop server...")
        task.wait(1)
        hopServer()
        return
    end

    for _, chest in ipairs(chests) do
        if chest and chest.Parent then
            tweenToChestUnderground(chest)
        end
    end

    task.wait(1)
    local remaining = getAllChests()
    if #remaining == 0 then
        print("🏃 Hết chest! Hop server...")
        task.wait(1)
        hopServer()
    else
        print("🎁 Còn", #remaining, "chest! Nhặt tiếp...")
        collectAllChests()
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Model") and obj.Name == "TreasureChest" then
        task.wait(0.3)
        tweenToChestUnderground(obj)
    end
end)

