-- ===================== DANH SÁCH TÊN CẦN TRÁNH =====================
local AVOID_NAMES = {
	"NightFlashTW",
	"Hashira_Kenji",
}

local function isAvoided(name)
	for _, n in ipairs(AVOID_NAMES) do
		if name == n then return true end
	end
	return false
end

-- ===================== SERVER HOP CẢI TIẾN =====================
local history = {}
local MAX_HISTORY = 50
local hopping = false

local function addHistory(serverId)
	table.insert(history, serverId)
	if #history > MAX_HISTORY then table.remove(history, 1) end
end

local function inHistory(serverId)
	for _, id in ipairs(history) do
		if id == serverId then return true end
	end
	return false
end

local function hopServer(reason)
	if hopping then return end
	hopping = true
	print("🔍 Hop server! Lý do: " .. (reason or "unknown"))

	local gameId = game.PlaceId
	local validServers = {}
	local cursor = ""
	local pages = 0

	repeat
		local url = ("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100"):format(gameId)
		if cursor ~= "" then url = url .. "&cursor=" .. cursor end
		local ok, result = pcall(function()
			return HttpService:JSONDecode(game:HttpGetAsync(url))
		end)
		if not ok then warn("❌ Lỗi:", result) break end
		for _, server in ipairs(result.data) do
			local playing = server.playing or 0
			if playing >= 6 and playing <= 18
				and server.id ~= game.JobId
				and not inHistory(server.id)
			then
				table.insert(validServers, server)
			end
		end
		cursor = result.nextPageCursor or ""
		pages = pages + 1
	until cursor == "" or pages >= 3

	if #validServers == 0 then
		warn("❌ Không tìm được server! Xóa lịch sử...")
		for i = 1, math.floor(MAX_HISTORY / 2) do
			table.remove(history, 1)
		end
		hopping = false
		return
	end

	local picked = validServers[math.random(1, #validServers)]
	addHistory(picked.id)
	print("➡️ Hop: " .. picked.id .. " | Players: " .. picked.playing)
	TeleportService:TeleportToPlaceInstance(gameId, picked.id, player)
end

