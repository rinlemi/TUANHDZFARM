-- Thread tracking
local threads = {}
local function stopAll()
    for _, t in pairs(threads) do
        task.cancel(t)
    end
    threads = {}
    StatusLabel.Text = "⛔ Đã dừng tất cả"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
end

local function setStatus(text, color)
    StatusLabel.Text = "● " .. text
    StatusLabel.TextColor3 = color or Color3.fromRGB(100, 255, 100)
end

-- Minimize
local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    for _, v in pairs(MainFrame:GetChildren()) do
        if v ~= Title and v ~= MinBtn then
            v.Visible = not minimized
        end
    end
    MainFrame.Size = minimized and UDim2.new(0, 220, 0, 40) or UDim2.new(0, 220, 0, 380)
    MinBtn.Text = minimized and "+" or "−"
end)

-- =====================
-- GRAVITY METEOR
-- =====================
BtnGravity.MouseButton1Click:Connect(function()
    stopAll()
    setStatus("Gravity Meteor đang chạy...", Color3.fromRGB(180, 100, 255))
    local t = task.spawn(function()
        local Players = game:GetService("Players")
        local chargeTime = 10
        local cooldown = 5
        local locations = {
            CFrame.new(-2657.96044921875, 232.58395385742188, -3761.018310546875, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            CFrame.new(-3594.859130859375, 249.02792358398438, -3807.361083984375, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            CFrame.new(-3434.383056640625, 294.19580078125, -4521.24169921875, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            CFrame.new(-2667.20947265625, 293.9255676269531, -4439.6123046875, 1, 0, 0, 0, 1, 0, 0, 0, 1),
        }
        local function throwMeteor(targetCFrame)
            local char = Players.LocalPlayer.Character
            local gravityRemote = char:WaitForChild("Powers"):WaitForChild("Gravity"):WaitForChild("RemoteEvent")
            local hotRemote = char:WaitForChild("Powers"):WaitForChild("Hot"):WaitForChild("RemoteEvent")
            local snowRemote = char:WaitForChild("Powers"):WaitForChild("Snow"):WaitForChild("RemoteEvent")
            local startCFrame = char.HumanoidRootPart.CFrame
            gravityRemote:FireServer("GravityPower6", "StartCharging", startCFrame, workspace:WaitForChild("Z_Island222"):WaitForChild("Model"):WaitForChild("Board"))
            task.wait(chargeTime)
            hotRemote:FireServer("HotPower1", "FlightDisabler") task.wait(0.1)
            snowRemote:FireServer("SnowPower4", "FlightDisabler") task.wait(0.1)
            gravityRemote:FireServer("GravityPower1", "FlightDisabler") task.wait(0.1)
            gravityRemote:FireServer("GravityPower6", "StopCharging", targetCFrame, nil, 300)
        end
        while true do
            for i, loc in ipairs(locations) do
                setStatus("Meteor địa điểm " .. i, Color3.fromRGB(180, 100, 255))
                throwMeteor(loc)
                task.wait(cooldown)
            end
        end
    end)
    table.insert(threads, t)
end)

