-- =====================
-- HAKI TRAINING
-- =====================
BtnHaki.MouseButton1Click:Connect(function()
    stopAll()
    setStatus("Haki Training đang chạy...", Color3.fromRGB(255, 150, 50))
    local t = task.spawn(function()
        local UserData = workspace:WaitForChild("UserData"):WaitForChild("User_1137442977")
        local III = UserData:WaitForChild("III")
        local UpdateHaki = UserData:WaitForChild("UpdateHaki")
        local holdTime = 20
        local cooldown = 10
        while true do
            UpdateHaki:FireServer() task.wait(0.5)
            III:FireServer("On", 231)
            task.wait(holdTime)
            III:FireServer("Off", 231) task.wait(0.5)
            UpdateHaki:FireServer()
            setStatus("Haki cooldown " .. cooldown .. "s...", Color3.fromRGB(255, 150, 50))
            task.wait(cooldown)
        end
    end)
    table.insert(threads, t)
end)

