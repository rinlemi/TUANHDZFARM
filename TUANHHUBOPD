local function fishingLoop(rodName)
	local fishing = RS:WaitForChild("Fishing")
	while running do
		local char = player.Character or player.CharacterAdded:Wait()
		pcall(function()
			char:WaitForChild(rodName):WaitForChild("Click"):FireServer(
				vector.create(7747.935546875, -5617.28759765625, 4095.056396484375)
			)
		end)
		task.wait(20)
		if not running then break end
		pcall(function()
			char:WaitForChild(rodName):WaitForChild("Click"):FireServer(
				vector.create(7747.935546875, -5617.28759765625, 4095.056396484375)
			)
		end)
		task.wait(0.3)
		if not running then break end
		pcall(function() fishing:FireServer("Start", "Easy") end)
		task.wait(0.2)
		for i = 1, 10 do
			if not running then break end
			pcall(function() fishing:FireServer("Running", "Default") end)
			task.wait(0.25)
		end
		task.wait(0.5)
		if not running then break end
		pcall(function() fishing:FireServer("Finish", 10) end)
		fishCount = fishCount + 1
		fishLabel.Text = "🐟 Cá: " .. fishCount .. " | 📦 Cache: " .. cacheCount
	end
end

local function stopFish()
	running = false
	if currentFishThread then task.cancel(currentFishThread) currentFishThread = nil end
	btnSuper.BackgroundColor3 = Color3.fromRGB(30, 80, 150)
	btnWood.BackgroundColor3 = Color3.fromRGB(100, 60, 20)
	btnSturdy.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	btnSuper.Text = "🎣 Super Rod: TẮT"
	btnWood.Text = "🪵 Wood Rod: TẮT"
	btnSturdy.Text = "🪨 Sturdy Rod: TẮT"
end

local function startFish(rodName, btn)
	if running then stopFish() return end
	stopFish()
	running = true
	btn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
	btn.Text = "⏹ Dừng " .. rodName
	currentFishThread = task.spawn(function() fishingLoop(rodName) end)
end

btnSuper.MouseButton1Click:Connect(function() startFish("Super Rod", btnSuper) end)
btnWood.MouseButton1Click:Connect(function() startFish("Wood Rod", btnWood) end)
