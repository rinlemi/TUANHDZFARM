-- TAB SYSTEM
local tabNames = {
	"🐟 Auto Fish",
	"🥤 Auto Drink",
	"⚡ Auto Haki",
	"💤 Auto AFK"
}

local tabs = {}
local pages = {}

local function createPage(name)
	local page = Instance.new("Frame", content)
	page.Size = UDim2.new(1,0,1,0)
	page.BackgroundTransparency = 1
	page.Visible = false
	
	local label = Instance.new("TextLabel", page)
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.Font = Enum.Font.GothamBold
	label.TextSize = 40
	label.TextColor3 = Color3.fromRGB(0,170,255)
	
	return page
end

local function switchTab(tabName)
	for name,page in pairs(pages) do
		page.Visible = (name == tabName)
	end
	
	for name,button in pairs(tabs) do
		if name == tabName then
			TweenService:Create(button,TweenInfo.new(0.2),{
				BackgroundColor3 = Color3.fromRGB(20,90,255)
			}):Play()
		else
			TweenService:Create(button,TweenInfo.new(0.2),{
				BackgroundColor3 = Color3.fromRGB(10,20,40)
			}):Play()
		end
	end
end

for i,name in ipairs(tabNames) do
	
	local btn = Instance.new("TextButton", tabsHolder)
	btn.Size = UDim2.new(0,150,0,48)
	btn.Position = UDim2.new(0,(i-1)*165+15,0.5,-24)
	btn.BackgroundColor3 = Color3.fromRGB(10,20,40)
	btn.BorderSizePixel = 0
	btn.Text = name
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 20
	btn.TextColor3 = Color3.fromRGB(255,255,255)
	
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,14)
	
	local s = Instance.new("UIStroke", btn)
	s.Color = Color3.fromRGB(0,120,255)
	
	btn.MouseEnter:Connect(function()
		if btn.BackgroundColor3 ~= Color3.fromRGB(20,90,255) then
			TweenService:Create(btn,TweenInfo.new(0.15),{
				BackgroundColor3 = Color3.fromRGB(15,35,65)
			}):Play()
		end
	end)
	
	btn.MouseLeave:Connect(function()
		if btn.BackgroundColor3 ~= Color3.fromRGB(20,90,255) then
			TweenService:Create(btn,TweenInfo.new(0.15),{
				BackgroundColor3 = Color3.fromRGB(10,20,40)
			}):Play()
		end
	end)
	
	btn.MouseButton1Click:Connect(function()
		switchTab(name)
	end)
	
	tabs[name] = btn
	pages[name] = createPage(name)
end

-- DEFAULT TAB
switchTab("🐟 Auto Fish")

-- DRAG
local dragging = false
local dragStart
local startPos

header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		
		local delta = input.Position - dragStart
		
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

