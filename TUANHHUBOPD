	lbl.TextSize = 13
	lbl.Font = Enum.Font.GothamBold
	Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 10)
	local s = Instance.new("UIStroke", lbl)
	s.Color = Color3.fromRGB(0, 120, 255)
	s.Thickness = 1
	return lbl
end

local function makeSep(parent)
	local sep = Instance.new("Frame", parent)
