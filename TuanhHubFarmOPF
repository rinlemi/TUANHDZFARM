-- ===================== BUILD LIST =====================
local allMobs = {}

local function isSelected(name)
	return selectedMobs[name] == true
end

local function buildList(filter)
	for _, v in ipairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end

	for _, name in ipairs(allMobs) do
		if filter == "" or name:lower():find(filter:lower()) then

			local btn = Instance.new("TextButton", scroll)
			btn.Size = UDim2.new(1, 0, 0, 26)
			btn.Text = "👾 " .. name
			btn.BackgroundColor3 = Color3.fromRGB(25,25,48)
			btn.TextColor3 = Color3.fromRGB(220,220,220)
			btn.Font = Enum.Font.GothamBold
			btn.TextSize = 11
			btn.TextXAlignment = Enum.TextXAlignment.Left
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)

			if isSelected(name) then
				btn.BackgroundColor3 = Color3.fromRGB(0,80,160)
			end

			btn.MouseButton1Click:Connect(function()
				if selectedMobs[name] then
					selectedMobs[name] = nil
					btn.BackgroundColor3 = Color3.fromRGB(25,25,48)
				else
					selectedMobs[name] = true
					btn.BackgroundColor3 = Color3.fromRGB(0,80,160)
				end

				-- update label
				local t = {}
				for k,v in pairs(selectedMobs) do
					if v then table.insert(t,k) end
				end

				selectedLabel.Text = "Selected: " .. (#t > 0 and table.concat(t,", ") or "none")
			end)
		end
	end
end

local function refresh()
	allMobs = getMobs()
	buildList(searchBox.Text)
end

