task.spawn(function()
	while true do
		task.wait(0.5)
		local count = getMobCount()
		if count > 0 then
			local nearest, dist = getNearestMobFromList(selectedMobs)
			local totalAlive = 0
			for name in pairs(selectedMobs) do
				totalAlive = totalAlive + getAliveCount(name)
			end
			aliveLabel.Text = "📊  Alive: " .. totalAlive
			if nearest then
				local hum = nearest:FindFirstChild("Humanoid")
				local hp  = hum and math.floor(hum.Health / hum.MaxHealth * 100) or 0
				distLabel.Text = "📏  Dist: " .. math.floor(dist or 0)
				hpLabel.Text   = "❤️  HP: " .. hp .. "%"
			else
				distLabel.Text = "📏  Dist: --"
				hpLabel.Text   = "❤️  HP: --"
			end
		else
			aliveLabel.Text = "📊  Alive: --"
			distLabel.Text  = "📏  Dist: --"
			hpLabel.Text    = "❤️  HP: --"
		end
	end
end)

-- ===================== AUTO ATTACK + AUTO SPAWN TP =====================
task.spawn(function()
	while true do
		task.wait(0.2)
		if getMobCount() == 0 then continue end
		if not getAutoAttack() then continue end

		local char = player.Character
		if not char then continue end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then continue end

		local nearest, dist = getNearestMobFromList(selectedMobs)
		if not nearest then continue end

		local mobHrp = nearest:FindFirstChild("HumanoidRootPart")
		if not mobHrp then continue end

		-- Auto Spawn TP
		if getAutoSpawn() then
			hrp.CFrame = mobHrp.CFrame * CFrame.new(0, 0, 3)
		end

		-- Auto Attack
		VirtualUser:Button1Down(Vector2.new(500, 500), workspace.CurrentCamera.CFrame)
		task.wait(0.05)
		VirtualUser:Button1Up(Vector2.new(500, 500), workspace.CurrentCamera.CFrame)
	end
end)

