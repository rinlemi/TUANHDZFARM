-- Toggles
local function makeToggle(parent, text, yPos, color)
	local frame = Instance.new("Frame", parent)
	frame.Size = UDim2.new(1, -10, 0, 28)
	frame.Position = UDim2.new(0, 5, 0, yPos)
	frame.BackgroundColor3 = Color3.fromRGB(20, 20, 40)
	frame.BorderSizePixel = 0
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.BackgroundTransparency = 1
	btn.Text = "☐ " .. text
	btn.TextColor3 = Color3.fromRGB(200, 200, 200)
	btn.TextSize = 12
	btn.Font = Enum.Font.GothamBold
	btn.TextXAlignment = Enum.TextXAlignment.Left
	local p = Instance.new("UIPadding", btn)
	p.PaddingLeft = UDim.new(0, 8)

	local on = false
	btn.MouseButton1Click:Connect(function()
		on = not on
		if on then
			btn.Text = "☑ " .. text
			btn.TextColor3 = color or Color3.fromRGB(0, 255, 100)
			frame.BackgroundColor3 = Color3.fromRGB(0, 60, 30)
		else
			btn.Text = "☐ " .. text
			btn.TextColor3 = Color3.fromRGB(200, 200, 200)
			frame.BackgroundColor3 = Color3.fromRGB(20, 20, 40)
		end
	end)

	return btn, function() return on end
end

