local function makeToggle(parent, text, yPos, onColor, offColor)
	offColor = offColor or C.card
	local frame = Instance.new("Frame", parent)
	frame.Size = UDim2.new(1, -16, 0, 30)
	frame.Position = UDim2.new(0, 8, 0, yPos)
	frame.BackgroundColor3 = offColor
	frame.BorderSizePixel = 0
	corner(7, frame)
	stroke(frame, Color3.fromRGB(50,40,90), 1)

	-- Pill indicator
	local pill = Instance.new("Frame", frame)
	pill.Size = UDim2.new(0, 28, 0, 14)
	pill.Position = UDim2.new(1, -36, 0.5, -7)
	pill.BackgroundColor3 = C.muted
	pill.BorderSizePixel = 0
	corner(7, pill)
	local pillDot = Instance.new("Frame", pill)
	pillDot.Size = UDim2.new(0, 12, 0, 12)
	pillDot.Position = UDim2.new(0, 1, 0, 1)
	pillDot.BackgroundColor3 = Color3.fromRGB(180,180,200)
	pillDot.BorderSizePixel = 0
	corner(6, pillDot)

	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(1, -44, 1, 0)
	btn.BackgroundTransparency = 1
	btn.Text = text
	btn.TextColor3 = C.muted
	btn.TextSize = 12
	btn.Font = Enum.Font.GothamBold
	btn.TextXAlignment = Enum.TextXAlignment.Left
	local p = Instance.new("UIPadding", btn)
	p.PaddingLeft = UDim.new(0, 10)

	local on = false
	local function setState(v)
		on = v
		if on then
			frame.BackgroundColor3 = Color3.fromRGB(30, 15, 70)
			pill.BackgroundColor3 = onColor or C.accent
			pillDot.Position = UDim2.new(0, 15, 0, 1)
			pillDot.BackgroundColor3 = Color3.fromRGB(255,255,255)
			btn.TextColor3 = onColor or C.accent
		else
			frame.BackgroundColor3 = offColor
			pill.BackgroundColor3 = C.muted
			pillDot.Position = UDim2.new(0, 1, 0, 1)
			pillDot.BackgroundColor3 = Color3.fromRGB(180,180,200)
			btn.TextColor3 = C.muted
		end
	end

	btn.MouseButton1Click:Connect(function()
		setState(not on)
	end)

	return btn, function() return on end, setState
end

