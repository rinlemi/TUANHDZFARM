local function restartLoopSkills()
    for k, thread in pairs(skillLoopThreads) do
        pcall(function() task.cancel(thread) end)
        skillLoopThreads[k] = nil
    end
    local keyMap = {Z=Enum.KeyCode.Z, X=Enum.KeyCode.X, C=Enum.KeyCode.C, V=Enum.KeyCode.V}
    for k, on in pairs(loopSkills) do
        if on then
            skillLoopThreads[k] = task.spawn(function()
                while loopSkills[k] do
                    pressKey(keyMap[k])
                    task.wait(0.15)
                end
            end)
        end
    end
end

