-- ===================== MOB LIST LOGIC =====================
local allMobs = {}
local mobButtons = {} -- name → button frame

local function getMobCount()
	local c = 0
	for _ in pairs(selectedMobs) do c = c + 1 end
	return c
end

local function updateSelectedLabel()
	local count = getMobCount()
	if count == 0 then
		selectedLabel.Text = "🎯  Selected: --"
		statusLabel.Text   = "● Idle"
		statusLabel.TextColor3 = C.muted
	elseif count == 1 then
		local name = next(selectedMobs)
		selectedLabel.Text = "🎯  Selected: " .. name
		statusLabel.Text   = "● Farming " .. name
		statusLabel.TextColor3 = C.green
	else
		selectedLabel.Text = "🎯  Selected: " .. count .. " mobs"
		statusLabel.Text   = "● Multi-farm (" .. count .. ")"
		statusLabel.TextColor3 = C.green
	end
end

local function buildList(filter)
	-- clear
	for _, v in ipairs(scroll:GetChildren()) do
		if v:IsA("Frame") then v:Destroy() end
	end
	mobButtons = {}

	for _, name in ipairs(allMobs) do
		if filter == "" or name:lower():find(filter:lower(), 1, true) then
			local row = Instance.new("Frame", scroll)
			row.Size = UDim2.new(1, 0, 0, 28)
			row.BackgroundColor3 = selectedMobs[name] and C.selectedBg or C.card
			row.BorderSizePixel = 0
			corner(6, row)

			-- Colored left bar if selected
			local bar = Instance.new("Frame", row)
			bar.Size = UDim2.new(0, 3, 1, -6)
			bar.Position = UDim2.new(0, 3, 0, 3)
			bar.BackgroundColor3 = C.accent
			bar.BorderSizePixel = 0
			bar.Visible = selectedMobs[name] == true
			corner(2, bar)

			local btn = Instance.new("TextButton", row)
			btn.Size = UDim2.new(1, 0, 1, 0)
			btn.BackgroundTransparency = 1
			btn.Text = "👾  " .. name
			btn.TextColor3 = selectedMobs[name] and C.white or C.muted
			btn.TextSize = 11
			btn.Font = Enum.Font.GothamBold
			btn.TextXAlignment = Enum.TextXAlignment.Left
			local p = Instance.new("UIPadding", btn)
			p.PaddingLeft = UDim.new(0, 12)

			mobButtons[name] = {row = row, btn = btn, bar = bar}

			btn.MouseButton1Click:Connect(function()
				-- TOGGLE: click again to deselect
				if selectedMobs[name] then
					selectedMobs[name] = nil
					row.BackgroundColor3 = C.card
					btn.TextColor3 = C.muted
					bar.Visible = false
				else
					selectedMobs[name] = true
					row.BackgroundColor3 = C.selectedBg
					btn.TextColor3 = C.white
					bar.Visible = true
				end
				updateSelectedLabel()
			end)
		end
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

local function refreshMobs()
	allMobs = getMobs()
	buildList(searchBox.Text)
	updateSelectedLabel()
end

