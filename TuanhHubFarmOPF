-- ===================== AUTO CHEST LOGIC =====================
local function hopServer(reason)
    print("🔍 Hop server... (" .. (reason or "") .. ")")
    local gameId = game.PlaceId
    local ok, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGetAsync(
            ("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100"):format(gameId)
        ))
    end)
    if not ok then warn("❌ Lỗi hop:", result) return end
    for _, server in ipairs(result.data) do
        if server.playing >= 9 and server.playing < server.maxPlayers and server.id ~= game.JobId then
            print("➡️ Hop:", server.id)
            TeleportService:TeleportToPlaceInstance(gameId, server.id, player)
            return
        end
    end
    warn("❌ Không tìm được server!")
end

local function tweenToChest(chest)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local ok, targetPos = pcall(function() return chest:GetPivot().Position end)
    if not ok or not chest.Parent then return end
    local startPos = hrp.Position
    local upPos = Vector3.new(startPos.X, startPos.Y + 400, startPos.Z)
    local tw0 = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(upPos)})
    tw0:Play(); tw0.Completed:Wait()
    if not chest.Parent then return end
    local tw1 = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos + Vector3.new(0,3,0))})
    tw1:Play(); tw1.Completed:Wait()
    task.wait(0.2)
    print("✅ Nhặt chest!")
end

local function getAllChests()
    local chests = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == "TreasureChest" then table.insert(chests, v) end
    end
    return chests
end

local function collectAllChests()
    if not autoChestOn then return end
    local chests = getAllChests()
    print("🎁 Tìm thấy", #chests, "chest!")
    if #chests == 0 then
        task.wait(1)
        return
    end
    for _, chest in ipairs(chests) do
        if not autoChestOn then return end
        if chest and chest.Parent then tweenToChest(chest) end
    end
    task.wait(1)
    local remaining = getAllChests()
    if #remaining > 0 then
        collectAllChests()
    end
end

workspace.DescendantAdded:Connect(function(obj)
