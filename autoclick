-- ✅ Hình tròn đặt đúng vị trí nút ROLL (góc dưới phải)
local clickPoint = Instance.new("Frame", gui)
clickPoint.Size = UDim2.new(0, 36, 0, 36)
clickPoint.Position = UDim2.new(1, -100, 1, -60) -- góc dưới phải gần nút ROLL
clickPoint.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
clickPoint.BorderSizePixel = 0
clickPoint.Active = true
clickPoint.ZIndex = 10
Instance.new("UICorner", clickPoint).CornerRadius = UDim.new(1, 0)
local pointStroke = Instance.new("UIStroke", clickPoint)
pointStroke.Color = Color3.fromRGB(255, 255, 255)
pointStroke.Thickness = 2

local dragLabel = Instance.new("TextLabel", clickPoint)
dragLabel.Size = UDim2.new(1, 0, 1, 0)
dragLabel.BackgroundTransparency = 1
dragLabel.Text = "✛"
dragLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
dragLabel.TextSize = 18
dragLabel.Font = Enum.Font.GothamBold
dragLabel.ZIndex = 11

-- DRAG
local dragging = false
local dragInput = nil
local lastPos = nil

clickPoint.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch
    or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragInput = input
        lastPos = Vector2.new(input.Position.X, input.Position.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == dragInput then
        dragging = false
        dragInput = nil
        lastPos = nil
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        local cur = Vector2.new(input.Position.X, input.Position.Y)
        if lastPos then
            local delta = cur - lastPos
            local cp = clickPoint.Position
            clickPoint.Position = UDim2.new(0, cp.X.Offset + delta.X, 0, cp.Y.Offset + delta.Y)
        end
        lastPos = cur
    end
end)

-- AUTO CLICK
local autoRunning = false
local clickThread = nil

local function getClickPos()
    local abs = clickPoint.AbsolutePosition
    local size = clickPoint.AbsoluteSize
    return Vector2.new(abs.X + size.X/2, abs.Y + size.Y/2)
end

local function startAutoClick()
    autoRunning = true
    statusLabel.Text = "✅ Đang roll..."
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    clickPoint.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    pointStroke.Color = Color3.fromRGB(255, 200, 0)

    clickThread = task.spawn(function()
        while autoRunning do
            if not dragging then
                local pos = getClickPos()
                pcall(function()
                    VIM:SendTouchEvent(0, Enum.UserInputState.Begin, pos.X, pos.Y)
                end)
                task.wait(0.08)
                pcall(function()
                    VIM:SendTouchEvent(0, Enum.UserInputState.End, pos.X, pos.Y)
                end)
                task.wait(0.5)
            end
            task.wait(0.05)
        end
    end)
end

local function stopAutoClick()
    autoRunning = false
    if clickThread then
        pcall(function() task.cancel(clickThread) end)
        clickThread = nil
    end
    statusLabel.Text = "⏸ Đang dừng"
    statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    clickPoint.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    pointStroke.Color = Color3.fromRGB(255, 255, 255)
end

btnOn.MouseButton1Click:Connect(function()
    if not autoRunning then startAutoClick() end
end)

btnOff.MouseButton1Click:Connect(function()
    stopAutoClick()
end)

