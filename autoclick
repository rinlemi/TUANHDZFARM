-- ========== DRAG LOGIC MOBILE ==========
local dragging = false
local dragInput = nil
local lastPos = nil

clickPoint.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragInput = input
        lastPos = Vector2.new(input.Position.X, input.Position.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == dragInput then
        dragging = false
        dragInput = nil
        lastPos = nil
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        local currentPos = Vector2.new(input.Position.X, input.Position.Y)
        if lastPos then
            local delta = currentPos - lastPos
            local cp = clickPoint.Position
            clickPoint.Position = UDim2.new(
                0, cp.X.Offset + delta.X,
                0, cp.Y.Offset + delta.Y
            )
        end
        lastPos = currentPos
    end
end)

-- ========== AUTO CLICK ==========
local autoRunning = false
local clickThread = nil

local function getClickPos()
    local abs = clickPoint.AbsolutePosition
    local size = clickPoint.AbsoluteSize
    return Vector2.new(abs.X + size.X / 2, abs.Y + size.Y / 2)
end

local function simulateClick(pos)
    -- ✅ Dùng TouchTap để giả lập chạm màn hình mobile
    local inputObject = InputObject.new()
    pcall(function()
        game:GetService("VirtualInputManager"):SendTouchEvent(
            0, Enum.UserInputState.Begin, pos.X, pos.Y
        )
        task.wait(0.05)
        game:GetService("VirtualInputManager"):SendTouchEvent(
            0, Enum.UserInputState.End, pos.X, pos.Y
        )
    end)
end

local function startAutoClick()
    autoRunning = true
    statusLabel.Text = "✅ Đang click..."
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    clickPoint.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    pointStroke.Color = Color3.fromRGB(255, 200, 0)

    clickThread = task.spawn(function()
        while autoRunning do
            if not dragging then
                local pos = getClickPos()
                pcall(function()
                    game:GetService("VirtualInputManager"):SendTouchEvent(
                        0, Enum.UserInputState.Begin, pos.X, pos.Y
                    )
                end)
                task.wait(0.05)
                pcall(function()
                    game:GetService("VirtualInputManager"):SendTouchEvent(
                        0, Enum.UserInputState.End, pos.X, pos.Y
                    )
                end)
            end
            task.wait(0.1)
        end
    end)
end

local function stopAutoClick()
    autoRunning = false
    if clickThread then
        pcall(function() task.cancel(clickThread) end)
        clickThread = nil
    end
    statusLabel.Text = "⏸ Đang dừng"
    statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    clickPoint.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    pointStroke.Color = Color3.fromRGB(255, 255, 255)
end

btnOn.MouseButton1Click:Connect(function()
    if not autoRunning then startAutoClick() end
end)

btnOff.MouseButton1Click:Connect(function()
    stopAutoClick()
end)

print("✅ Auto Click Mobile loaded!")
