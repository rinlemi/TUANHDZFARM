-- ========== DRAG LOGIC ==========
local dragging = false
local lastMousePos = nil

clickPoint.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        lastMousePos = UserInputService:GetMouseLocation()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        lastMousePos = nil
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and lastMousePos then
        local currentMouse = UserInputService:GetMouseLocation()
        local delta = currentMouse - lastMousePos
        lastMousePos = currentMouse

        local currentPos = clickPoint.Position
        clickPoint.Position = UDim2.new(
            0, currentPos.X.Offset + delta.X,
            0, currentPos.Y.Offset + delta.Y
        )
    end
end)

-- ========== AUTO CLICK ==========
local autoRunning = false
local clickThread = nil
local VIM = game:GetService("VirtualInputManager")

local function getClickPos()
    local abs = clickPoint.AbsolutePosition
    local size = clickPoint.AbsoluteSize
    return Vector2.new(abs.X + size.X / 2, abs.Y + size.Y / 2)
end

local function startAutoClick()
    autoRunning = true
    statusLabel.Text = "✅ Đang click..."
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    clickPoint.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    pointStroke.Color = Color3.fromRGB(255, 200, 0)

    clickThread = task.spawn(function()
        while autoRunning do
            if not dragging then
                local pos = getClickPos()
                VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 0)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)
            end
            task.wait(0.05)
        end
    end)
end

local function stopAutoClick()
    autoRunning = false
    if clickThread then
        pcall(function() task.cancel(clickThread) end)
        clickThread = nil
    end
    statusLabel.Text = "⏸ Đang dừng"
    statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    clickPoint.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    pointStroke.Color = Color3.fromRGB(255, 255, 255)
end

btnOn.MouseButton1Click:Connect(function()
    if not autoRunning then startAutoClick() end
end)

btnOff.MouseButton1Click:Connect(function()
    stopAutoClick()
end)

print("✅ Auto Click loaded!")
