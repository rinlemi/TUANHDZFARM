-- Auto Cache loop
local function useAllCache()
	local char = player.Character
	if not char then return end
	local backpack = player.Backpack
	for _, item in ipairs(backpack:GetChildren()) do
		if item.Name:find("Cache") then
			item.Parent = char
			task.wait(0.3)
			pcall(function() char:FindFirstChild(item.Name):Activate() end)
			cacheCount = cacheCount + 1
			cacheLabel.Text = "📦 Cache dùng: " .. cacheCount
			task.wait(0.3)
		end
	end
end

local function cacheLoop()
	while cacheRunning do
		useAllCache()
		task.wait(2)
	end
end

btnCache.MouseButton1Click:Connect(function()
	cacheRunning = not cacheRunning
	if cacheRunning then
		btnCache.Text = "📦 Auto Cache: BẬT"
		btnCache.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
		cacheThread = task.spawn(cacheLoop)
	else
		btnCache.Text = "📦 Auto Cache: TẮT"
		btnCache.BackgroundColor3 = Color3.fromRGB(60, 20, 80)
		if cacheThread then
			task.cancel(cacheThread)
			cacheThread = nil
		end
	end
end)

local function fishingLoop(rodName)
	local fishing = RS:WaitForChild("Fishing")
	while running do
		local char = player.Character or player.CharacterAdded:Wait()
		pcall(function()
			char:WaitForChild(rodName):WaitForChild("Click"):FireServer(
				vector.create(7747.935546875, -5617.28759765625, 4095.056396484375)
			)
		end)
		print("🎣 Thả cần... chờ 35s")
		task.wait(35)
		if not running then break end
		pcall(function()
			char:WaitForChild(rodName):WaitForChild("Click"):FireServer(
				vector.create(7747.935546875, -5617.28759765625, 4095.056396484375)
			)
		end)
		task.wait(0.3)
		if not running then break end
		pcall(function() fishing:FireServer("Start", "Easy") end)
		task.wait(0.2)
		for i = 1, 10 do
			if not running then break end
			pcall(function() fishing:FireServer("Running", "Default") end)
			print("⚡ Tick " .. i .. "/10")
			task.wait(0.25)
		end
		task.wait(0.5)
		if not running then break end
		pcall(function() fishing:FireServer("Finish", 10) end)
		fishCount = fishCount + 1
		counterLabel.Text = "🐟 Cá câu được: " .. fishCount
		print("🐟 Nhận cá! Tổng: " .. fishCount)
		task.wait(2)
	end
end

