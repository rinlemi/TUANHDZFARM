}

local function makeTabContent()
	local frame = Instance.new("ScrollingFrame", content)
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundTransparency = 1
	frame.BorderSizePixel = 0
	frame.ScrollBarThickness = 4
	frame.Visible = false
	Instance.new("UIListLayout", frame).Padding = UDim.new(0, 8)
	return frame
end

local function switchTab(name)
	for n, f in pairs(tabContents) do
		f.Visible = (n == name)
	end
	for n, btn in pairs(tabs) do
		if n == name then
			btn.BackgroundColor3 = tabColors[table.find(tabNames, n)] or Color3.fromRGB(0, 120, 200)
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			btn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
			btn.TextColor3 = Color3.fromRGB(180, 180, 180)
		end
	end
	activeTab = name
end

local tabWidth = math.floor(680 / #tabNames)
for i, name in ipairs(tabNames) do
	local btn = Instance.new("TextButton", tabBar)
	btn.Size = UDim2.new(0, tabWidth - 5, 0, 32)
	btn.Position = UDim2.new(0, (i-1) * tabWidth + 5, 0, 4)
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
	btn.BorderSizePixel = 0
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(180, 180, 180)
	btn.TextSize = 12
	btn.Font = Enum.Font.GothamBold
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
	tabs[name] = btn
	tabContents[name] = makeTabContent()
	btn.MouseButton1Click:Connect(function() switchTab(name) end)
end

