local function useAllCache()
	local char = player.Character
	if not char then return end
	for _, item in ipairs(player.Backpack:GetChildren()) do
		if item.Name:find("Cache") then
			item.Parent = char
			task.wait(0.3)
			pcall(function() char:FindFirstChild(item.Name):Activate() end)
			cacheCount = cacheCount + 1
			fishLabel.Text = "🐟 Cá: " .. fishCount .. " | 📦 Cache: " .. cacheCount
			task.wait(0.3)
		end
	end
end

btnCache.MouseButton1Click:Connect(function()
	cacheRunning = not cacheRunning
	if cacheRunning then
		btnCache.Text = "📦 Auto Cache: BẬT"
		btnCache.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
		cacheThread = task.spawn(function()
			while cacheRunning do useAllCache() task.wait(2) end
		end)
	else
		btnCache.Text = "📦 Auto Cache: TẮT"
		btnCache.BackgroundColor3 = Color3.fromRGB(60, 20, 80)
		if cacheThread then task.cancel(cacheThread) cacheThread = nil end
	end
end)

