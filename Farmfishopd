	lbl.TextSize = 12
	lbl.Font = Enum.Font.GothamBold
	Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 6)
	return lbl
end

local function makeSep(parent)
	local sep = Instance.new("Frame", parent)
	sep.Size = UDim2.new(1, -20, 0, 2)
	sep.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
	sep.BorderSizePixel = 0
	return sep
end

local function makePad(parent)
	local p = Instance.new("Frame", parent)
	p.Size = UDim2.new(1, 0, 0, 4)
	p.BackgroundTransparency = 1
	return p
end

